procedure TWaspForm.SetupMainPanel(form: TForm);
var
  panel: TPanel;
begin
  panel.Create(form);
  panel.setName('main_panel');
  panel.setCaption('');
  panel.setWidth(Self.Size.X);
  panel.setHeight(Self.Size.Y);
  panel.setBevelWidth(0);
  panel.setColor($1A1814);
  Self.SetupScriptsPanel(panel);
end;

procedure TWaspForm.OnShow(sender: TObject);
var
  text: TLabel;
  status: TLabel;
begin
  text := Self.Form.GetChild('source_bash_label');
  if text <> nil then
    text.SetFontColor($FFFFFF);
  text := Self.Form.GetChild('source_local_label');
  if text <> nil then
    text.SetFontColor($FFFFFF);

  status := Self.Form.GetChild('license_status_label');
  if (status <> nil) and BashLicenseClient.HasKey() then
  begin
    BashLicenseClient.FetchEntitlements(True);
    if BashLicenseClient.Valid then
    begin
      if BashLicenseClient.ExpiresAt <> '' then
        status.setCaption('Expires - ' + FormatLicenseExpiryDate(BashLicenseClient.ExpiresAt))
      else
        status.setCaption('License active - lifetime');
      status.SetFontColor($3DCF7A);
    end
    else
    begin
      if BashLicenseClient.LastError = 'license_expired' then
        status.setCaption('License expired')
      else
        status.setCaption('Invalid or revoked key');
      status.SetFontColor($4C5DE8);
    end;
  end;

  Self.PopulateScripts();
end;

procedure TWaspForm.Setup();
begin
  Self.Size := [TControl.AdjustToDPI(920), TControl.AdjustToDPI(640)];

  Self.Form.Init(nil);
  Self.Form.SetName('bash_form');
  Self.Form.setCaption('B.A.S.H - BigAussie Script House');
  Self.Form.setWidth(Self.Size.X);
  Self.Form.setHeight(Self.Size.Y);
  Self.Form.getConstraints().SetInterfaceConstraints(Self.Size.X, Self.Size.Y, Self.Size.X, Self.Size.Y);
  Self.Form.setPosition(TPosition.poScreenCenter);
  Self.Form.setColor($1A1814);
  Self.Form.setOnShow(@Self.OnShow);

  with Self.Form.getFont() do
  begin
    setQuality(TFontQuality.fqAntialiased);
    setPitch(TFontPitch.fpFixed);
    SetColor($F2EDE4);
  end;

  Self.SetupMainPanel(Self.Form);
end;

procedure TWaspForm.Show();
begin
  try
    Self.Form.ShowModal();
  except
    Writeln(GetExceptionMessage());
  finally
    Self.Form.Free();
  end;
end;

procedure TWaspForm.Run();
begin
  Self.Setup();
  Sync(@Self.Show);
end;

function BashLauncherPath(): String;
begin
  Result := ScriptPath + BASH_LAUNCHER_FILE;
end;

function BashDefaultSimbaBody(): String;
begin
  Result :=
    '(* Thank you for choosing B.A.S.H — BigAussie Script House *)' + LineEnding +
    '(* Discord: https://discord.gg/qsmKs5uKfR *)' + LineEnding +
    LineEnding +
    '(* To start simply double click the green play button. *)' + LineEnding +
    LineEnding +
    'begin' + LineEnding +
    '  SimbaRunInTab(ScriptPath + ''bash-launcher.simba'');' + LineEnding +
    'end.' + LineEnding;
end;

function PatchDefaultSimbaToBashLauncher(): Boolean;
var
  path, content: String;
begin
  Result := False;
  if not FileExists(BashLauncherPath()) then
    Exit;

  path := AppPath + 'Data' + DirectorySeparator + 'default.simba';
  try
    if FileExists(path) then
      content := ReadFileContents(path)
    else
      content := '';
  except
    content := '';
  end;

  if content.Contains('bash-launcher.simba') and (not content.Contains('wasp-launcher.simba')) then
    Exit(True);

  try
    if WriteFileContents(path, BashDefaultSimbaBody(), False) then
    begin
      WriteLn('[B.A.S.H] Replaced Data\default.simba to open bash-launcher.simba');
      Exit(True);
    end;
  except
  end;
end;

procedure MigrateBashLauncherPaths();
begin
  PatchDefaultSimbaToBashLauncher();
end;

function ReadScriptHeaderField(path, afterToken, beforeToken: String): String;
var
  content: String;
begin
  Result := '';
  if not FileExists(path) then
    Exit;
  try
    content := ReadFileContents(path);
  except
    Exit;
  end;
  if Length(content) > 8192 then
    content := Copy(content, 1, 8192);
  Result := content.After(afterToken).Before(beforeToken);
end;

function ReadScriptIdFromFile(path: String): String;
begin
  Result := ReadScriptHeaderField(path, 'SCRIPT_ID := ''', '''}');
  if Result = '' then
    Result := ReadScriptHeaderField(path, 'SCRIPT_ID := "', '"}');
end;

function ReadScriptRevisionFromFile(path: String): Int32;
var
  revStr: String;
begin
  revStr := ReadScriptHeaderField(path, 'SCRIPT_REVISION := ''', '''}');
  if revStr = '' then
    revStr := ReadScriptHeaderField(path, 'SCRIPT_REVISION := "', '"}');
  Result := StrToIntDef(revStr, 0);
end;

function IsBashLauncherFile(path: String): Boolean;
begin
  Result := SameText(ReadScriptIdFromFile(path), {$MACRO SCRIPT_ID});
end;

function WriteBashLauncherFile(dest, body: String): Boolean;
var
  tmp, bak, dir: String;
begin
  Result := False;
  if Length(body) < 500 then
    Exit;

  dir := ExtractFilePath(dest);
  if (dir <> '') and (not DirectoryExists(dir)) then
  begin
    if not ForceDirectories(dir) then
      Exit;
  end;

  try
    if WriteFileContents(dest, body, False) then
      Exit(True);
  except
  end;

  tmp := dest + '.tmp';
  bak := dest + '.bak';
  try
    if FileExists(tmp) then
      DeleteFile(tmp);
    if not WriteFileContents(tmp, body, False) then
      Exit;

    try
      if FileExists(dest) then
        WriteFileContents(bak, ReadFileContents(dest), False);
    except
    end;

    if FileExists(dest) and (not DeleteFile(dest)) then
    begin
      if FileExists(dest + '.new') then
        DeleteFile(dest + '.new');
      if not RenameFile(tmp, dest + '.new') then
        DeleteFile(tmp);
      Exit;
    end;

    if RenameFile(tmp, dest) then
      Exit(True);

    Result := WriteFileContents(dest, body, False);
    if FileExists(tmp) then
      DeleteFile(tmp);
  except
    if FileExists(tmp) then
      DeleteFile(tmp);
  end;
end;

function DownloadBashLauncherBody(): String;
var
  http, code: Int32;
begin
  Result := '';
  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    SetHTTPHeader(http, 'Accept', '*/*');
    try
      SetSocketTimeout(http, 60000);
    except
    end;

    Result := GetHTTPPage(http, BASH_LAUNCHER_GITHUB_RAW);
    code := GetHTTPResponseCode(http);
    if (code = 200) and (Length(Result) >= 500) then
      Exit;

    Result := GetHTTPPage(http, BASH_PREMIUM_API + '/v1/launcher/download');
    code := GetHTTPResponseCode(http);
    if (code <> 200) or (Length(Result) < 500) then
      Result := '';
  except
    Result := '';
  finally
    FreeHTTPClient(http);
  end;
end;

function DownloadBashLauncherToFile(dest: String): Boolean;
var
  http, code: Int32;
  tmp, dir: String;
begin
  Result := False;
  dir := ExtractFilePath(dest);
  if (dir <> '') and (not DirectoryExists(dir)) then
  begin
    if not ForceDirectories(dir) then
      Exit;
  end;

  tmp := dest + '.download';
  if FileExists(tmp) then
    DeleteFile(tmp);

  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    SetHTTPHeader(http, 'Accept', '*/*');
    try
      SetSocketTimeout(http, 60000);
    except
    end;

    WriteLn('[B.A.S.H] Downloading launcher from GitHub...');
    code := GetHTTPPageEx(http, BASH_LAUNCHER_GITHUB_RAW, tmp);
    if (code <> 200) or (not FileExists(tmp)) then
    begin
      WriteLn('[B.A.S.H] GitHub download failed (HTTP ', code, ').');
      if FileExists(tmp) then
        DeleteFile(tmp);
      Exit;
    end;

    try
      if Length(ReadFileContents(tmp)) < 500 then
      begin
        WriteLn('[B.A.S.H] GitHub download was empty/too small.');
        DeleteFile(tmp);
        Exit;
      end;
    except
      DeleteFile(tmp);
      Exit;
    end;

    if FileExists(dest) and (not DeleteFile(dest)) then
    begin
      if FileExists(dest + '.new') then
        DeleteFile(dest + '.new');
      if RenameFile(tmp, dest + '.new') then
        WriteLn('[B.A.S.H] Destination locked; saved as ', dest, '.new')
      else
        DeleteFile(tmp);
      Exit;
    end;

    if RenameFile(tmp, dest) then
      Exit(True);

    try
      Result := CopyFile(tmp, dest, True);
    except
      Result := False;
    end;
    if FileExists(tmp) then
      DeleteFile(tmp);
  except
    WriteLn('[B.A.S.H] DownloadBashLauncherToFile error: ', GetExceptionMessage());
    if FileExists(tmp) then
      DeleteFile(tmp);
  finally
    FreeHTTPClient(http);
  end;
end;

procedure FinishBashLauncherRestart();
begin
  WriteLn('[B.A.S.H] Launcher ready at bash-launcher.simba — press New / play to open it');
  try
    SimbaCloseCurrentTab();
  except
  end;
  TerminateScript();
end;

function InstallBashLauncherToDefaultPath(): Boolean;
var
  dest, body: String;
begin
  Result := False;
  dest := BashLauncherPath();

  // Prefer the running file when it is already this launcher (V5 wrote V8 into wasp-launcher.simba).
  if IsBashLauncherFile(ScriptFile) then
  begin
    try
      body := ReadFileContents(ScriptFile);
    except
      body := '';
    end;
    if WriteBashLauncherFile(dest, body) then
    begin
      WriteLn('[B.A.S.H] Installed launcher to ', dest, ' from running file');
      Exit(True);
    end;
  end;

  if DownloadBashLauncherToFile(dest) then
  begin
    WriteLn('[B.A.S.H] Installed launcher to ', dest, ' from GitHub');
    Exit(True);
  end;

  body := DownloadBashLauncherBody();
  if WriteBashLauncherFile(dest, body) then
  begin
    WriteLn('[B.A.S.H] Installed launcher to ', dest);
    Exit(True);
  end;
end;

procedure EnsureBashLauncherOnDefaultPath();
var
  dest, body: String;
  selfRev, installedRev: Int32;
  legacyWasp, needsInstall, looksLikeLegacyWasp: Boolean;
begin
  dest := BashLauncherPath();
  selfRev := StrToIntDef({$MACRO SCRIPT_REVISION}, 1);
  legacyWasp := SameText(ExtractFileName(ScriptFile), 'wasp-launcher.simba');

  installedRev := ReadScriptRevisionFromFile(dest);
  looksLikeLegacyWasp := False;
  if FileExists(dest) and IsBashLauncherFile(dest) then
  begin
    try
      body := ReadFileContents(dest);
      looksLikeLegacyWasp := body.Contains('BASH_LAUNCHER_FILE') and body.Contains('''wasp-launcher.simba''');
    except
    end;
  end;

  needsInstall :=
    legacyWasp or
    (not FileExists(dest)) or
    (not IsBashLauncherFile(dest)) or
    (installedRev < selfRev) or
    looksLikeLegacyWasp;

  if needsInstall then
  begin
    WriteLn(
      '[B.A.S.H] Migrating launcher to ', dest,
      ' (installed rev ', Max(installedRev, 0),
      ', local rev ', selfRev,
      ', from ', ExtractFileName(ScriptFile), ')'
    );
    if not InstallBashLauncherToDefaultPath() then
    begin
      WriteLn('[B.A.S.H] Launcher install failed for: ', dest);
      if FileExists(dest + '.new') then
        MessageDlg(
          'B.A.S.H',
          'Downloaded launcher but could not replace the open file.' + LineEnding + LineEnding +
            'Close every tab for bash-launcher.simba, then either:' + LineEnding +
            '1) Run this script again, or' + LineEnding +
            '2) Rename:' + LineEnding + dest + '.new' + LineEnding +
            '   to bash-launcher.simba',
          TMsgDlgType.mtWarning,
          []
        )
      else
        MessageDlg(
          'B.A.S.H',
          'Could not install launcher to:' + LineEnding + dest + LineEnding + LineEnding +
            'Check your internet connection and that GitHub is reachable.',
          TMsgDlgType.mtWarning,
          []
        );
      Exit;
    end;
  end;

  MigrateBashLauncherPaths();

  // V5 users land here after update wrote V8 into wasp-launcher.simba.
  // Close so New / play opens bash-launcher via the replaced default.simba.
  if legacyWasp then
    FinishBashLauncherRestart();
end;

procedure CheckBashLauncherUpdate();
var
  http, code, remoteRev, localRev: Int32;
  response, body, dest: String;
  json: TJSONObject;
begin
  {$IFDEF DEVELOPER_MODE}
  EnsureBashLauncherOnDefaultPath();
  Exit;
  {$ENDIF}

  localRev := StrToIntDef({$MACRO SCRIPT_REVISION}, 1);
  dest := BashLauncherPath();
  if IsBashLauncherFile(dest) then
    localRev := Max(localRev, ReadScriptRevisionFromFile(dest));

  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    SetHTTPHeader(http, 'Accept', 'application/json');
    try
      SetSocketTimeout(http, 15000);
    except
    end;

    response := GetHTTPPage(http, BASH_PREMIUM_API + '/v1/launcher');
    code := GetHTTPResponseCode(http);
    if code = 404 then
    begin
      EnsureBashLauncherOnDefaultPath();
      Exit;
    end;
    if code <> 200 then
    begin
      EnsureBashLauncherOnDefaultPath();
      Exit;
    end;

    try
      json.Init(response);
    except
      EnsureBashLauncherOnDefaultPath();
      Exit;
    end;

    try
      remoteRev := json.optInt('revision', 0);
    finally
      json.Free();
    end;

    if remoteRev <= localRev then
    begin
      EnsureBashLauncherOnDefaultPath();
      Exit;
    end;

    WriteLn('[B.A.S.H] Remote launcher update ', localRev, ' -> ', remoteRev);
    SetHTTPHeader(http, 'Accept', '*/*');
    body := GetHTTPPage(http, BASH_PREMIUM_API + '/v1/launcher/download');
    code := GetHTTPResponseCode(http);
    if (code <> 200) or (Length(body) < 500) then
    begin
      WriteLn('[B.A.S.H] Launcher download failed. Falling back to local install...');
      EnsureBashLauncherOnDefaultPath();
      Exit;
    end;

    // Always write updates to bash-launcher.simba (never wasp-launcher.simba).
    if not WriteBashLauncherFile(dest, body) then
    begin
      WriteLn('[B.A.S.H] Remote write failed. Falling back to local install...');
      EnsureBashLauncherOnDefaultPath();
      Exit;
    end;

    WriteLn('[B.A.S.H] Launcher installed to ', dest);
    MigrateBashLauncherPaths();
    FinishBashLauncherRestart();
  except
    WriteLn('[B.A.S.H] Launcher update failed: ', GetExceptionMessage());
    EnsureBashLauncherOnDefaultPath();
  finally
    FreeHTTPClient(http);
  end;
end;

var
  WaspForm: TWaspForm;

{$ENDIF}
{$ENDIF}
{$ENDIF}
{$ENDIF}
{$ENDIF}
{$ENDIF}
{$ENDIF}
{$ENDIF}
{$ENDIF}
{$ENDIF}
{$ENDIF}

begin
  ClearDebug();
  WaspAsync.Setup();
  LauncherConfig.Setup(AppPath + 'Configs' + DirectorySeparator + 'bash-launcher.json');
  BashScriptClient.Setup();
  BashLicenseClient.Setup();
  WaspUpdater.Setup();
  GitHubClient.Setup();
  CheckBashLauncherUpdate();
  EnsureBashUiAssets();
  WaspForm.Run();
end;
