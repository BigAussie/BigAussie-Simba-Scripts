  localRadio.Create(sourcePanel);
  localRadio.setName('source_local_radio');
  localRadio.setCaption('');
  localRadio.SetLeft(TControl.AdjustToDPI(145));
  localRadio.SetTop(radioTop);
  localRadio.setWidth(TControl.AdjustToDPI(18));
