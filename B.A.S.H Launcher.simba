  licenseStatus.SetTop(saveBtn.GetTop() + TControl.AdjustToDPI(4));
  licenseStatus.SetLeft(clearBtn.GetLeft() + clearBtn.getWidth() + TControl.AdjustToDPI(8));

  activityCaption.Create(panel);
  activityCaption.setName('activity_filter_caption');
  activityCaption.setCaption('Filter by Activity');
  activityCaption.SetFontColor($A89F90);
  activityCaption.SetFontSize(9);
  activityCaption.SetLeft(TControl.AdjustToDPI(16));
  activityCaption.SetTop(listTop);

  categoryPanel.Create(panel);
  categoryPanel.setName('activity_category_panel');
  categoryPanel.setCaption('');
  categoryPanel.setBevelWidth(0);
  categoryPanel.setColor($1A1814);
  categoryPanel.SetLeft(TControl.AdjustToDPI(16));
  categoryPanel.SetTop(activityCaption.GetTop() + activityCaption.GetTrueHeight() + TControl.AdjustToDPI(4));
  categoryPanel.setWidth(TControl.AdjustToDPI(280));
  categoryPanel.setHeight(TControl.AdjustToDPI(24));

  catIds := String(BASH_CATEGORY_IDS).Split(',');
  catLabels := String(BASH_CATEGORY_LABELS).Split(',');
  ax := 0;
  gap := TControl.AdjustToDPI(2);
  for ai := 0 to High(catIds) do
  begin
    if catIds[ai] = 'all' then
      catW := TControl.AdjustToDPI(20)
    else if catIds[ai] = 'combat' then
      catW := TControl.AdjustToDPI(50)
    else if catIds[ai] = 'gathering' then
      catW := TControl.AdjustToDPI(58)
    else if catIds[ai] = 'production' then
      catW := TControl.AdjustToDPI(66)
    else if catIds[ai] = 'utility' then
      catW := TControl.AdjustToDPI(36)
    else
      catW := TControl.AdjustToDPI(36);

    categoryBtn.Create(categoryPanel);
    categoryBtn.setName('activity_cat_' + catIds[ai]);
    if ai <= High(catLabels) then
      categoryBtn.SetCaption(catLabels[ai])
    else
      categoryBtn.SetCaption(catIds[ai]);
    categoryBtn.SetLeft(ax);
    categoryBtn.SetTop(0);
    categoryBtn.setWidth(catW);
    categoryBtn.setHeight(TControl.AdjustToDPI(22));
    categoryBtn.setColor($24201C);
    categoryBtn.SetFontColor($F2EDE4);
    categoryBtn.SetFontSize(7);
    categoryBtn.SetOnClick(@Self._OnCategoryClick);
    ax += catW + gap;
  end;

  activityPanel.Create(panel);
  activityPanel.setName('activity_filter_panel');
  activityPanel.setCaption('');
  activityPanel.setBevelWidth(0);
  activityPanel.setColor($1A1814);
  activityPanel.SetLeft(TControl.AdjustToDPI(16));
  activityPanel.SetTop(categoryPanel.GetTop() + categoryPanel.getHeight() + TControl.AdjustToDPI(4));
  activityPanel.setWidth(TControl.AdjustToDPI(280));
  activityPanel.setHeight(TControl.AdjustToDPI(31));
  activityPanel.setVisible(False);

  actIds := String(BASH_ACTIVITY_IDS).Split(',');
  iconSize := TControl.AdjustToDPI(25);
  iconPad := TControl.AdjustToDPI(3);
  aw := iconSize + (iconPad * 2);
  ah := iconSize + (iconPad * 2);
  for ai := 0 to High(actIds) do
  begin
    activityCell.Create(activityPanel);
    activityCell.setName('activity_btn_' + actIds[ai]);
    activityCell.setCaption('');
    activityCell.setBevelWidth(0);
    activityCell.SetLeft(0);
    activityCell.SetTop(0);
    activityCell.setWidth(aw);
    activityCell.setHeight(ah);
    activityCell.setColor($24201C);
    activityCell.setHint(ActivityLabelForId(actIds[ai]));
    activityCell.setShowHint(True);
    activityCell.setOnClick(@Self._OnActivityFilterClick);
    activityCell.setVisible(False);

    iconPath := ActivityIconPath(actIds[ai]);
    if FileExists(iconPath) then
    begin
      activityIcon.Create(activityCell);
      activityIcon.setName('activity_icon_' + actIds[ai]);
      activityIcon.SetLeft(iconPad);
      activityIcon.SetTop(iconPad);
      activityIcon.setWidth(iconSize);
      activityIcon.setHeight(iconSize);
      activityIcon.SetStretch(True);
      activityIcon.SetProportional(True);
      activityIcon.setHint(ActivityLabelForId(actIds[ai]));
      activityIcon.setShowHint(True);
      activityIcon.setOnClick(@Self._OnActivityFilterClick);
      try
        activityIcon.getPicture().LoadFromFile(iconPath);
      except
      end;
    end;
  end;

  Self.RefreshCategoryChips();
  Self.RefreshActivityIconLayout();

  scriptsList.Create(panel);
  scriptsList.SetName('scripts');
  scriptsList.Panel.setName('script_list_panel');
  scriptsList.SetCaption('Scripts');
  scriptsList.Caption.SetFontColor($A89F90);
  scriptsList.SetLeft(TControl.AdjustToDPI(16));
  scriptsList.SetTop(categoryPanel.GetTop() + categoryPanel.getHeight() + TControl.AdjustToDPI(6));
  scriptsList.SetWidth(TControl.AdjustToDPI(280));
  scriptsList.setHeight(Max(TControl.AdjustToDPI(120), licensePanel.GetTop() - scriptsList.GetTop() - TControl.AdjustToDPI(6)));
  scriptsList.ListBox.ListBox.setOnClick(@Self._OnScriptChange);
  scriptsList.ListBox.ListBox.setOnKeyPress(@Self._OnScriptOnKeyDown);
  scriptsList.ListBox.ListBox.setStyle(TListBoxStyle.lbOwnerDrawFixed);
  scriptsList.ListBox.ListBox.setOnDrawItem(@Self.OnDrawItem);
  scriptsList.ListBox.ListBox.setColor($1A1814);

  Self.RelayoutScriptList();

  Self.SetupVersionsPanel(panel, TControl.AdjustToDPI(12));

  Self.SetupScriptPanel(
    panel,
    [
      scriptsList.GetRight() + colGap,
      categoryPanel.GetTop() + categoryPanel.getHeight() + TControl.AdjustToDPI(4) - TControl.AdjustToDPI(20)
    ]
  );

  if BashScriptClient.IsLocalSource() then
  begin
    Self._SetDescriptionVisible(False);
    Self._SetDiscordCtaVisible(False);
  end;

  button.Create(panel);
  button.setName('script_open_button');
  button.SetCaption('Open script');
  button.SetOnClick(@Self._OpenScriptEx);
  button.setWidth(TControl.AdjustToDPI(150));
  button.setHeight(TControl.AdjustToDPI(25));
  button.SetTop(footerTop + TControl.AdjustToDPI(35));
  button.SetLeft(panel.getWidth() - TControl.AdjustToDPI(16) - button.getWidth());

  Self.SetupColorLegend(panel);

  launcherRev.Create(panel);
  launcherRev.setName('launcher_revision_label');
  launcherRev.setCaption('Launcher revision: ' + ToStr(WaspUpdater.Launcher.Revision));
  launcherRev.SetFontSize(9);
  launcherRev.SetFontColor($A89F90);
  launcherRev.SetTop(footerTop + TControl.AdjustToDPI(65));
  launcherRev.setLeft(Self.Size.X div 2 - launcherRev.GetTrueWidth() div 2);
