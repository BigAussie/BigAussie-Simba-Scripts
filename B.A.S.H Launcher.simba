{$IFNDEF WS_UPDATER_INCLUDED}
{$DEFINE WS_UPDATER_INCLUDED}

type
  TScriptFile = record
    URL: String;
    ID: String;
    Revision: Int32;
    Path: String;
  end;

  TScriptFileArray = array of TScriptFile;

  TWaspUpdater = record
    Name: String;
    Launcher: TScriptFile;

    Scripts: TScriptFileArray;
    ScriptsPath: String;

    MonitorSRLT: TMonitor;
    MonitorWL: TMonitor;
  end;

var
  WaspUpdater: TWaspUpdater;

procedure TMonitor.NextState(); forward;

procedure TMonitor.Fail(const reason: String);
begin
  Self.State := EMonitorState.NONE;
  Self.CurrentFile := '';
  Self.Timer.setEnabled(False);

  if Self.Caption <> nil then
  begin
    Self.Caption.setCaption(reason);
    Self.Caption.SetFontColor($4C5DE8);
    Self.Caption.Repaint();
  end;

  if Self.Button <> nil then
    Self.Button.setEnabled(True);

  WriteLn('[B.A.S.H updater] ', Self.Package, ': ', reason);
end;

procedure TMonitor._OnTimer(sender: TObject);
var
  doneFile, failFile: String;
begin
  doneFile := WaspAsync.Path + Self.CurrentFile;
  failFile := StringReplace(doneFile, '.done', '.fail', []);

  if FileExists(failFile) then
  begin
    DeleteFile(failFile);
    TTimer(sender).SetEnabled(False);
    if Self.State = EMonitorState.DOWNLOAD then
      Self.Fail('Rate limited')
    else
      Self.Fail('Failed');
    Exit;
  end;

  if FileExists(doneFile) and DeleteFile(doneFile) then
  begin
    TTimer(sender).SetEnabled(False);
    Self.NextState();
    Exit;
  end;


  if (Self.State = EMonitorState.DOWNLOAD) and (Self.StartedAt > 0) and (GetTickCount() - Self.StartedAt > 120000) then
  begin
    TTimer(sender).SetEnabled(False);
    Self.Fail('Timed out');
  end;
end;

procedure TMonitor.NextState();
var
  params: TStringArray;
begin
  Self.State := EMonitorState(Ord(Self.State) + 1);
  if Self.State > High(EMonitorState) then
    Self.State := EMonitorState.NONE;

  case Self.State of
    EMonitorState.DOWNLOAD:
    begin
      Self.CurrentFile := 'downloader-' + LowerCase(Self.Package) + '.done';
      Self.StartedAt := GetTickCount();

      if not GitHubClient.HasDownloadURL(Self.Package) then
      begin
        Self.Fail('Rate limited');
        Exit;
      end;

      GitHubClient.Download(Self.Package);

      Self.Caption.setCaption('Downloading');
      Self.Caption.SetFontColor($D4A017);
      Self.Caption.Repaint();
      if Self.Button <> nil then
        Self.Button.setEnabled(False);

      Self.Timer.SetEnabled(True);
    end;

    EMonitorState.UNZIP:
    begin
      Self.CurrentFile := 'unzipper-' + LowerCase(Self.Package) + '.done';
      Self.StartedAt := GetTickCount();
      params := ['path=' + GitHubClient.DownloadPath, 'name=' + Self.Package];
      WaspAsync.Run('unzipper', params);

      Self.Caption.setCaption('Unzipping');
      Self.Caption.SetFontColor($D4A017);
      Self.Caption.Repaint();

      Self.Timer.SetEnabled(True);
    end;

    EMonitorState.CLEAN:
    begin
      Self.CurrentFile := 'mover-' + LowerCase(Self.Package) + '.done';
      Self.StartedAt := GetTickCount();
      params := ['origin=' + GitHubClient.DownloadPath, 'pkg=' + Self.Package];
      WaspAsync.Run('mover', params);

      Self.Caption.setCaption('Cleaning');
      Self.Caption.SetFontColor($D4A017);
      Self.Caption.Repaint();

      Self.Timer.SetEnabled(True);
    end;

    EMonitorState.NONE:
    begin
      Self.CurrentFile := '';
      Self.StartedAt := 0;

      case LowerCase(Self.Package) of
        'srl-t', 'srlt':
        begin
          GitHubClient.Packages.Current.SRLT := GitHubClient.GetCurrentPackageVersion(SRLT_INSTALL_DIR);
          if GitHubClient.Packages.Current.SRLT = '' then
            Self.Caption.setCaption('Missing')
          else
            Self.Caption.setCaption('v.' + GitHubClient.Packages.Current.SRLT);

          if GitHubClient.Packages.Current.SRLT <> GitHubClient.Packages.Latest.SRLT then
            Self.Caption.SetFontColor($4C5DE8)
          else
            Self.Caption.SetFontColor($3DCF7A);
          Self.Caption.Repaint();
        end;
        'wasplib', 'wl':
        begin
          GitHubClient.Packages.Current.WaspLib := GitHubClient.GetCurrentPackageVersion(WASPLIB_INSTALL_DIR);
          if GitHubClient.Packages.Current.WaspLib = '' then
            Self.Caption.setCaption('Missing')
          else
            Self.Caption.setCaption('v.' + GitHubClient.Packages.Current.WaspLib);

          if GitHubClient.Packages.Current.WaspLib <> GitHubClient.Packages.Latest.WaspLib then
            Self.Caption.SetFontColor($4C5DE8)
          else
            Self.Caption.SetFontColor($3DCF7A);
          Self.Caption.Repaint();
        end;
      end;

      Self.Caption.Repaint();
      if Self.Button <> nil then
        Self.Button.setEnabled(True);
      Self.Timer.setEnabled(False);
    end;
  end;
end;

procedure TMonitor.RunMonitor(caption, button: TComponent);
begin
  if not Self.IsSetup then
  begin
    Self.Caption := caption;
    Self.Button := button;
    Self.Timer.setOnTimer(@Self._OnTimer);
    Self.IsSetup := True;
  end;

  Self.State := EMonitorState.NONE;
  Self.NextState();
end;

procedure TWaspUpdater.Update(pkg: String; caption, button: TComponent);
begin
  case pkg of
    'srlt':    Self.MonitorSRLT.RunMonitor(caption, button);
    'wasplib': Self.MonitorWL.RunMonitor(caption, button);
  end;
end;

function TWaspUpdater.GetScriptFileEx(filepath: String): TScriptFile;
var
  fileContent, idStr, revStr: String;
begin
  Result.URL := ExtractFileName(filepath).Before('.simba');
  Result.Path := filepath;
  fileContent := ReadFileContents(filepath);

  idStr := fileContent.After('SCRIPT_ID := ''').Before('''}');
  if idStr = '' then
    idStr := fileContent.After('SCRIPT_ID := "').Before('"}');

  if idStr = '' then
    idStr := ExtractFileName(filepath);
  Result.ID := idStr;

  revStr := fileContent.After('SCRIPT_REVISION := ''').Before('''}');
  if revStr = '' then
    revStr := fileContent.After('SCRIPT_REVISION := "').Before('"}');
  Result.Revision := StrToIntDef(revStr, 0);


  if (Result.Revision = 0) and FileExists(filepath) then
    Result.Revision := 1;
end;

function TWaspUpdater.GetScriptFiles(): TScriptFileArray;
var
  files: TStringArray;
  i: Int32;
  script: TScriptFile;
begin
  if Self.Scripts <> [] then Exit(Self.Scripts);

  files := GetFiles(Self.ScriptsPath, 'simba');
  for i := 0 to High(files) do
  begin
    script := Self.GetScriptFileEx(Self.ScriptsPath + files[i]);
    if script.Path <> '' then
      Result += script;
  end;

  Self.Scripts := Result;
end;

function TWaspUpdater.GetScriptFile(id: String): TScriptFile;
var
  i: Int32;
  scripts: TScriptFileArray;
  fileName: String;
begin
  scripts := Self.GetScriptFiles();
  for i := 0 to High(scripts) do
    if id = scripts[i].ID then
      Exit(scripts[i]);


  fileName := ExtractFileName(id);
  for i := 0 to High(scripts) do
  begin
    if (fileName <> '') and (ExtractFileName(scripts[i].Path) = fileName) then
      Exit(scripts[i]);
    if (fileName <> '') and (scripts[i].URL = fileName.Before('.simba')) then
      Exit(scripts[i]);
  end;
end;

procedure TWaspUpdater.UpdateScriptFileRevision(script: TScriptFile);
var
  i: Int32;
begin
  for i := 0 to High(Self.Scripts) do
    if Self.Scripts[i].ID = script.ID then
    begin
      Self.Scripts[i] := script;
      Exit;
    end;

  Self.Scripts += script;
end;

procedure TWaspUpdater.UpdateScript(script: TScriptData);
var
  path: String;
  installed: TScriptFile;
begin
  BashScriptClient.DownloadScript(script);
  path := Self.ScriptsPath + ExtractFileName(script.URL);
  if not FileExists(path) then
    Exit;

  installed := Self.GetScriptFileEx(path);

  if (script.ID <> '') and (installed.ID <> script.ID) then
    installed.ID := script.ID;
  if installed.Revision = 0 then
    installed.Revision := Max(script.Revision, 1);

  Self.UpdateScriptFileRevision(installed);
end;


procedure TWaspUpdater.Free();
begin
  Self.MonitorSRLT.Timer.Free();
  Self.MonitorWL.Timer.Free();
end;

procedure TWaspUpdater.Setup();
begin
  Self.Name := 'BashUpdater';
  Self.Launcher.ID := {$macro SCRIPT_ID};
  Self.Launcher.Revision := StrToIntDef({$macro SCRIPT_REVISION}, 1);

  Self.Launcher.Path := ScriptPath + BASH_LAUNCHER_FILE;
  Self.ScriptsPath := ScriptPath + 'bigaussie' + DirectorySeparator;

  if not ForceDirectories(Self.ScriptsPath) then
    TerminateScript('BashUpdater can''t create scripts directory.');;

  Self.MonitorSRLT.Package := 'srl-t';
  Self.MonitorSRLT.Timer.Init(nil);
  Self.MonitorSRLT.Timer.setName('srlt_update_monitor');
  Self.MonitorSRLT.Timer.setInterval(200);

  Self.MonitorWL.Package := 'wasplib';
  Self.MonitorWL.Timer.Init(nil);
  Self.MonitorWL.Timer.setName('wl_update_monitor');
  Self.MonitorWL.Timer.setInterval(200);

  AddOnTerminate(@Self.Free);
end;

{$IFNDEF WS_FORM_INCLUDED}
{$DEFINE WS_FORM_INCLUDED}

type
  TWaspForm = record
    Form: TForm;
    Size: TPoint;
    ActivityFilter: String;
    ActivityCategory: String;
    VisibleScripts: TScriptDataArray;
    Updating: record
      Script: Boolean;
    end;
  end;

function TWaspForm.GetSelectedScript(out script: TScriptData): Boolean;
var
  list: TListBox;
  idx: Int32;
begin
  Result := False;
  list := Self.Form.GetChild('scripts_listbox');
  if (list = nil) or (list.getItemIndex() < 0) then
    Exit;
  idx := list.getItemIndex();
  if (idx < 0) or (idx > High(Self.VisibleScripts)) then
    Exit;
  script := Self.VisibleScripts[idx];
  Result := True;
end;

function ActivityIconPath(const activityId: String): String;
var
  candidates: TStringArray;
  i: Int32;
begin
  candidates := [
    ExtractFilePath(ScriptFile) + BASH_ACTIVITY_ICON_DIR + activityId + '.bmp',
    BASH_ASSETS_DIR + 'activities' + DirectorySeparator + activityId + '.bmp',
    IncludePath + 'WaspLib' + DirectorySeparator + 'utils' + DirectorySeparator +
      'assets' + DirectorySeparator + 'activities' + DirectorySeparator + activityId + '.bmp'
  ];
  for i := 0 to High(candidates) do
    if FileExists(candidates[i]) then
      Exit(candidates[i]);
  Result := candidates[1];
end;

function BashLogoPath(): String;
var
  candidates: TStringArray;
  i: Int32;
begin
  candidates := [
    ExtractFilePath(ScriptFile) + 'assets' + DirectorySeparator + BASH_LOGO_NAME,
    BASH_ASSETS_DIR + BASH_LOGO_NAME,
    IncludePath + 'WaspLib' + DirectorySeparator + 'utils' + DirectorySeparator +
      'assets' + DirectorySeparator + BASH_LOGO_NAME
  ];
  for i := 0 to High(candidates) do
    if FileExists(candidates[i]) then
      Exit(candidates[i]);
  Result := candidates[1];
end;

function DownloadBashAsset(const relativePath, destPath: String): Boolean;
var
  http, code: Int32;
  url, destDir: String;
begin
  Result := False;
  if FileExists(destPath) then
    Exit(True);

  destDir := ExtractFilePath(destPath);
  if (destDir <> '') and (not DirectoryExists(destDir)) then
    if not ForceDirectories(destDir) then
    begin
      WriteLn('[B.A.S.H] Could not create assets folder: ', destDir);
      Exit(False);
    end;

  url := BASH_ASSETS_RAW + EncodeGitHubPath(relativePath.Replace('\', '/'));
  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    code := GetHTTPPageEx(http, url, destPath);
    Result := (code = 200) and FileExists(destPath);
    if Result then
      WriteLn('[B.A.S.H] Downloaded asset: ', relativePath)
    else
    begin
      WriteLn('[B.A.S.H] Asset download failed (HTTP ', code, '): ', relativePath);
      if FileExists(destPath) then
        DeleteFile(destPath);
    end;
  except
    WriteLn('[B.A.S.H] Asset download error: ', GetExceptionMessage());
    if FileExists(destPath) then
      DeleteFile(destPath);
    Result := False;
  finally
    FreeHTTPClient(http);
  end;
end;

procedure EnsureBashUiAssets();
var
  ids: TStringArray;
  i: Int32;
  id, dest: String;
begin
  if not FileExists(BashLogoPath()) then
  begin
    dest := BASH_ASSETS_DIR + BASH_LOGO_NAME;
    DownloadBashAsset(BASH_LOGO_NAME, dest);
  end;

  ids := String(BASH_ACTIVITY_IDS).Split(',');
  for i := 0 to High(ids) do
  begin
    id := Trim(ids[i]);
    if id = '' then
      Continue;
    if FileExists(ActivityIconPath(id)) then
      Continue;
    dest := BASH_ASSETS_DIR + 'activities' + DirectorySeparator + id + '.bmp';
    DownloadBashAsset('activities/' + id + '.bmp', dest);
  end;
end;

procedure TWaspForm.RefreshCategoryChips();
var
  panel: TPanel;
  btn: TButton;
  ids: TStringArray;
  i: Int32;
  name, cat: String;
begin
  panel := Self.Form.GetChild('activity_category_panel');
  if panel = nil then
    Exit;

  cat := LowerCase(Trim(Self.ActivityCategory));
  if cat = '' then
    cat := 'all';

  ids := String(BASH_CATEGORY_IDS).Split(',');
  for i := 0 to High(ids) do
  begin
    name := 'activity_cat_' + ids[i];
    btn := panel.GetChild(name);
    if btn = nil then
      Continue;
    if ids[i] = cat then
    begin
      btn.setColor($3A2E14);
      btn.SetFontColor($D4A017);
    end
    else
    begin
      btn.setColor($24201C);
      btn.SetFontColor($F2EDE4);
    end;
  end;
end;

procedure TWaspForm.RefreshActivityIconLayout();
var
  panel, cell: TPanel;
  ids, showIds: TStringArray;
  i, ax, aw, ah, gap, iconSize, iconPad: Int32;
  name, filter, cat: String;
  showIcons: Boolean;
begin
  panel := Self.Form.GetChild('activity_filter_panel');
  if panel = nil then
    Exit;

  cat := LowerCase(Trim(Self.ActivityCategory));
  if cat = '' then
    cat := 'all';
  filter := LowerCase(Trim(Self.ActivityFilter));
  if filter = '' then
    filter := 'all';

  ids := String(BASH_ACTIVITY_IDS).Split(',');
  for i := 0 to High(ids) do
  begin
    cell := panel.GetChild('activity_btn_' + ids[i]);
    if cell <> nil then
      cell.setVisible(False);
  end;

  showIcons := cat <> 'all';
  panel.setVisible(showIcons);
  if not showIcons then
  begin
    panel.setHeight(0);
    Exit;
  end;

  showIds := GetCategoryActivityIds(cat);
  iconSize := TControl.AdjustToDPI(25);
  iconPad := TControl.AdjustToDPI(3);
  aw := iconSize + (iconPad * 2);
  ah := iconSize + (iconPad * 2);
  gap := TControl.AdjustToDPI(4);
  ax := 0;

  for i := 0 to High(showIds) do
  begin
    name := 'activity_btn_' + showIds[i];
    cell := panel.GetChild(name);
    if cell = nil then
      Continue;
    cell.setVisible(True);
    cell.SetLeft(ax);
    cell.SetTop(0);
    if showIds[i] = filter then
      cell.setColor($D4A017)
    else
      cell.setColor($24201C);
    ax += aw + gap;
  end;

  panel.setHeight(ah);
end;

procedure TWaspForm.RelayoutScriptList();
var
  categoryPanel, activityPanel, licensePanel, scriptsPanel: TPanel;
  scriptPanel, inner, outer: TPanel;
  listBox: TListBox;
  captionLabel: TLabel;
  topY, listHeight, iconRow, darkH, darkW, gap, scriptTop: Int32;
begin
  categoryPanel := Self.Form.GetChild('activity_category_panel');
  activityPanel := Self.Form.GetChild('activity_filter_panel');
  licensePanel := Self.Form.GetChild('license_panel');
  scriptsPanel := Self.Form.GetChild('script_list_panel');
  if (categoryPanel = nil) or (scriptsPanel = nil) or (licensePanel = nil) then
    Exit;

  gap := TControl.AdjustToDPI(6);
  topY := categoryPanel.GetTop() + categoryPanel.getHeight() + TControl.AdjustToDPI(4);

  if (activityPanel <> nil) and (LowerCase(Trim(Self.ActivityCategory)) <> 'all') then
  begin
    activityPanel.setVisible(True);
    activityPanel.SetTop(topY);
    iconRow := activityPanel.getHeight();
    if iconRow < TControl.AdjustToDPI(31) then
    begin
      iconRow := TControl.AdjustToDPI(31);
      activityPanel.setHeight(iconRow);
    end;
    topY := activityPanel.GetTop() + iconRow + TControl.AdjustToDPI(8);
  end
  else if activityPanel <> nil then
  begin
    activityPanel.setVisible(False);
    activityPanel.setHeight(0);
  end;

  scriptsPanel.SetTop(topY);
  listHeight := licensePanel.GetTop() - topY - gap;
  if listHeight < 1 then
    listHeight := 1;
  scriptsPanel.setHeight(listHeight);

  listBox := scriptsPanel.GetChild('scripts_listbox');
  if listBox <> nil then
  begin
    inner := listBox.getParent();
    if inner <> nil then
    begin
      outer := inner.getParent();
      captionLabel := scriptsPanel.GetChild('scripts_label');
      if captionLabel <> nil then
        darkH := listHeight - captionLabel.getHeight()
      else
        darkH := listHeight - TControl.AdjustToDPI(15);
      if darkH < 1 then
        darkH := 1;
      darkW := scriptsPanel.getWidth();
      if darkW < 1 then
        darkW := 1;

      if outer <> nil then
      begin
        outer.setWidth(darkW);
        outer.setHeight(darkH);
      end;
      inner.setWidth(Max(1, darkW - 4));
      inner.setHeight(Max(1, darkH - 4));
      listBox.setWidth(darkW);
      listBox.setHeight(darkH);
    end;
  end;

  scriptPanel := Self.Form.GetChild('script_panel');
  if scriptPanel <> nil then
  begin
    scriptTop := categoryPanel.GetTop() + categoryPanel.getHeight() + TControl.AdjustToDPI(4) - TControl.AdjustToDPI(20);
    scriptPanel.SetTop(scriptTop);
    scriptPanel.setHeight(Max(TControl.AdjustToDPI(40), licensePanel.GetTop() - scriptTop));
  end;
end;

procedure TWaspForm.PopulateScripts();
var
  msPanel: TPanel;
  scripts: TScriptDataArray;
  listBox: TListBox;
  i, idx: Int32;
  lastKey, filter, category: String;
begin
  msPanel := Self.Form.GetChild('main_panel');
  scripts := BashScriptClient.GetScripts();
  filter := LowerCase(Trim(Self.ActivityFilter));
  category := LowerCase(Trim(Self.ActivityCategory));
  if filter = '' then
    filter := 'all';
  if category = '' then
    category := 'all';

  Self.VisibleScripts := [];
  for i := 0 to High(scripts) do
    if ScriptMatchesFilter(scripts[i], filter, category) then
      Self.VisibleScripts += scripts[i];

  listBox := msPanel.GetChild('scripts_listbox');
  listBox.Clear();
  idx := -1;

  if BashScriptClient.IsLocalSource() then
    lastKey := LauncherConfig.GetString('last_local_script')
  else
    lastKey := LauncherConfig.GetString('last_script');

  for i := 0 to High(Self.VisibleScripts) do
  begin
    listBox.getItems().Add(Self.VisibleScripts[i].Name);
    if Self.VisibleScripts[i].ID = lastKey then
      idx := i;
  end;

  Self.RefreshCategoryChips();
  Self.RefreshActivityIconLayout();
  Self.RelayoutScriptList();

  if listBox.getItems().getCount() = 0 then
  begin
    Self._OnScriptChange(listBox);
    Exit;
  end;

  if idx = -1 then
  begin
    listBox.setItemIndex(0);
    if BashScriptClient.IsLocalSource() then
      LauncherConfig.Remove('last_local_script')
    else
      LauncherConfig.Remove('last_script');
  end
  else
    listBox.setItemIndex(idx);

  Self._OnScriptChange(listBox);
end;

procedure TWaspForm._OnCategoryClick(sender: TObject);
var
  ctrl: TControl;
  name, id: String;
begin
  ctrl := sender;
  name := ctrl.getName();
  if not name.StartsWith('activity_cat_') then
    Exit;
  id := Copy(name, Length('activity_cat_') + 1, Length(name));
  if id = '' then
    id := 'all';
  if LowerCase(Trim(Self.ActivityCategory)) = id then
    Exit;
  Self.ActivityCategory := id;
  Self.ActivityFilter := 'all';
  Self.PopulateScripts();
end;

procedure TWaspForm._OnActivityFilterClick(sender: TObject);
var
  ctrl: TControl;
  name, id: String;
begin
  ctrl := sender;
  name := ctrl.getName();
  if name.StartsWith('activity_icon_') then
    id := Copy(name, Length('activity_icon_') + 1, Length(name))
  else if name.StartsWith('activity_btn_') then
    id := Copy(name, Length('activity_btn_') + 1, Length(name))
  else
    Exit;
  if id = '' then
    Exit;

  if LowerCase(Trim(Self.ActivityFilter)) = id then
    Self.ActivityFilter := 'all'
  else
    Self.ActivityFilter := id;
  Self.PopulateScripts();
end;

procedure TWaspForm._OnSourceChange(sender: TObject);
var
  radio: TRadioButton;
  bashRadio, localRadio: TRadioButton;
  source: EScriptSource;
  name: String;
begin
  name := TControl(sender).getName();

  if name = 'source_local_label' then
  begin
    localRadio := Self.Form.GetChild('source_local_radio');
    if localRadio <> nil then
      localRadio.SetChecked(True);
    source := EScriptSource.LOCAL;
  end
  else if name = 'source_bash_label' then
  begin
    bashRadio := Self.Form.GetChild('source_bash_radio');
    if bashRadio <> nil then
      bashRadio.SetChecked(True);
    source := EScriptSource.BASH;
  end
  else
  begin
    radio := sender;
    if name = 'source_local_radio' then
      source := EScriptSource.LOCAL
    else
      source := EScriptSource.BASH;

    if not radio.IsChecked() then
      Exit;
  end;

  if source = BashScriptClient.ActiveSource then
    Exit;

  BashScriptClient.SetActiveSource(source);
  Self.PopulateScripts();
end;

procedure TWaspForm._SetDescriptionVisible(visible: Boolean);
var
  panel: TPanel;
begin
  panel := Self.Form.GetChild('script_omemo_panel');
  if panel <> nil then
    panel.setVisible(visible);
end;

procedure OpenBashDiscord(sender: TObject);
begin
  OpenWebPage(BASH_DISCORD_URL);
end;

procedure TWaspForm._SetDiscordCtaVisible(visible: Boolean);
var
  panel, memoOuter, memoInner: TPanel;
  cta: TLabel;
  memo: TMemo;
  memoTop: Int32;
begin
  panel := Self.Form.GetChild('script_panel');
  if panel = nil then Exit;

  cta := panel.GetChild('script_discord_cta_label');
  if cta <> nil then
    cta.setVisible(visible);

  memoOuter := panel.GetChild('script_omemo_panel');
  if memoOuter = nil then Exit;

  if visible then
    memoTop := TControl.AdjustToDPI(48)
  else
    memoTop := TControl.AdjustToDPI(36);

  memoOuter.SetTop(memoTop);
  memoOuter.setHeight(panel.getHeight() - memoTop);

  memoInner := memoOuter.GetChild('script_imemo_panel');
  if memoInner <> nil then
  begin
    memoInner.setWidth(memoOuter.getWidth() - TControl.AdjustToDPI(2));
    memoInner.setHeight(memoOuter.getHeight() - TControl.AdjustToDPI(2));
    memo := memoInner.GetChild('script_content_memo');
    if memo <> nil then
    begin
      memo.setWidth(memoInner.getWidth() + TControl.AdjustToDPI(2));
      memo.setHeight(memoInner.getHeight() + TControl.AdjustToDPI(2));
    end;
  end;
end;

procedure TWaspForm._OpenScript(sender: TObject);
var
  list: TListBox;
  script: TScriptData;
  scriptFile: TScriptFile;
  path: String;
begin
  list := sender;
  if list.getItemIndex() < 0 then Exit;
  if not Self.GetSelectedScript(script) then Exit;

  if BashScriptClient.IsLocalSource() then
  begin
    LauncherConfig.Put('last_local_script', script.ID);
    path := script.LocalPath;
    if path = '' then
      path := script.URL;
    if (path = '') or (not FileExists(path)) then Exit;
    SimbaOpenInTab(path);
    Self.Form.Close();
    Exit;
  end;

  LauncherConfig.Put('last_script', script.ID);
  scriptFile := WaspUpdater.GetScriptFile(script.ID);
  if (scriptFile.Path = '') or (not FileExists(scriptFile.Path)) then Exit;
  SimbaOpenInTab(scriptFile.Path);
  Self.Form.Close();
end;

procedure TWaspForm._OpenScriptEx(sender: TObject);
var
  panel: TPanel;
begin
  panel := TButton(sender).getOwner();
  Self._OpenScript(panel.GetChild('scripts_listbox'));
end;

procedure TWaspForm._UpdateSRL();
var
  panel: TPanel;
  caption, button: TComponent;
begin
  panel := Self.Form.GetChild('current_version_panel');
  caption := panel.GetChild('current_srl_label');
  panel := panel.GetOwner();
  button := panel.GetChild('update_srl_button');
  WaspUpdater.Update('srlt', caption, button);
end;

procedure TWaspForm._UpdateWL();
var
  panel: TPanel;
  caption, button: TComponent;
begin
  panel := Self.Form.GetChild('current_version_panel');
  caption := panel.GetChild('current_wl_label');
  panel := panel.GetOwner();
  button := panel.GetChild('update_wl_button');
  WaspUpdater.Update('wasplib', caption, button);
end;

procedure TWaspForm._UpdateScript();
var
  list: TListBox;
  script: TScriptData;
  button: TButton;
  oldCaption: String;
begin
  if Self.Updating.Script then Exit;
  if BashScriptClient.IsLocalSource() then Exit;

  list := Self.Form.GetChild('scripts_listbox');
  if (list = nil) or (list.getItemIndex() < 0) then Exit;

  if not Self.GetSelectedScript(script) then Exit;
  if (script.Typ = EScriptType.PREMIUM_NO_SUB) or (script.Typ = EScriptType.TESTING_NO_SUB) or (script.Typ = EScriptType.FULL_NO_SUB) then
  begin
    MessageDlg(
      'B.A.S.H',
      '"' + script.Name + '" requires an active license key.' + LineEnding +
      'Enter your key in the License field, then try again.',
      TMsgDlgType.mtWarning,
      []
    );
    Exit;
  end;

  button := Self.Form.GetChild('update_script_button');
  oldCaption := '';
  if button <> nil then
  begin
    oldCaption := button.getCaption();
    button.setEnabled(False);
    button.setCaption('Downloading...');
    button.Repaint();
  end;

  try
    Self.Updating.Script := True;
    WaspUpdater.UpdateScript(script);
    Self._OnScriptChange(list);
  finally
    Self.Updating.Script := False;
    if (button <> nil) and (oldCaption <> '') and (button.getCaption() = 'Downloading...') then
    begin
      button.setCaption(oldCaption);
      button.setEnabled(True);
    end;
  end;
end;

procedure TWaspForm._SaveLicenseKey(sender: TObject);
var
  edit: TEdit;
  status: TLabel;
  key: String;
  scripts: TScriptDataArray;
begin
  edit := Self.Form.GetChild('license_key_edit');
  if edit = nil then Exit;

  key := System.Trim(edit.getText());
  BashLicenseClient.SetKey(key, True);
  BashScriptClient.InvalidateCatalog();

  status := Self.Form.GetChild('license_status_label');
  if key = '' then
  begin
    if status <> nil then
    begin
      status.setCaption('No license key saved');
      status.SetFontColor($A89F90);
    end;
    Self.PopulateScripts();
    Exit;
  end;

  scripts := BashLicenseClient.FetchEntitlements(True);
  if BashLicenseClient.Valid then
  begin
    if status <> nil then
    begin
      if BashLicenseClient.ExpiresAt <> '' then
        status.setCaption('Expires - ' + FormatLicenseExpiryDate(BashLicenseClient.ExpiresAt))
      else
        status.setCaption('License active - lifetime');
      status.SetFontColor($3DCF7A);
    end;
  end
  else
  begin
    if status <> nil then
    begin
      if BashLicenseClient.LastError = 'license_expired' then
        status.setCaption('License expired')
      else
        status.setCaption('Invalid or revoked key');
      status.SetFontColor($4C5DE8);
    end;
    if BashLicenseClient.LastError = 'license_expired' then
      MessageDlg(
        'B.A.S.H',
        'This license key has expired.' + LineEnding +
        'Local script copies are kept, but premium catalog/updates are unavailable until renewed.',
        TMsgDlgType.mtWarning,
        []
      )
    else
      MessageDlg(
        'B.A.S.H',
        'License key was rejected.' + LineEnding +
        'Local script copies are kept, but premium catalog/updates are unavailable.',
        TMsgDlgType.mtWarning,
        []
      );
  end;

  Self.PopulateScripts();
end;

procedure TWaspForm._ClearLicenseKey(sender: TObject);
var
  edit: TEdit;
  status: TLabel;
begin
  edit := Self.Form.GetChild('license_key_edit');
  if edit <> nil then
    edit.setText('');

  BashLicenseClient.ClearKey();
  BashScriptClient.InvalidateCatalog();

  status := Self.Form.GetChild('license_status_label');
  if status <> nil then
  begin
    status.setCaption('No license key saved');
    status.SetFontColor($A89F90);
  end;

  Self.PopulateScripts();
end;

procedure TWaspForm._OnScriptChange(sender: TObject);
var
  list: TListBox;
  main, panel: TPanel;
  text: TLabel;
  memo: TMemo;
  update, open: TButton;
  scriptData: TScriptData;
  scriptFile: TScriptFile;
  localPath: String;
  isLocal: Boolean;
begin
  list := sender;
  main := Self.Form.GetChild('main_panel');
  if main = nil then Exit;

  panel := main.GetChild('version_panel');
  update := nil;
  if panel <> nil then
    update := panel.GetChild('update_script_button');
  open := main.GetChild('script_open_button');

  if list.getItemIndex() < 0 then
  begin
    Self._SetDescriptionVisible(not BashScriptClient.IsLocalSource());
    Self._SetDiscordCtaVisible(False);
    if open <> nil then
    begin
      open.setEnabled(False);
      open.setCaption('Open script');
    end;
    if update <> nil then
    begin
      update.setEnabled(False);
      if BashScriptClient.IsLocalSource() then
        update.setCaption('Local')
      else
        update.setCaption('Install');
    end;
    Exit;
  end;
  list.Repaint();

  if not Self.GetSelectedScript(scriptData) then
    Exit;
  isLocal := BashScriptClient.IsLocalSource() or (scriptData.Source = EScriptSource.LOCAL);

  if isLocal then
  begin
    localPath := scriptData.LocalPath;
    if localPath = '' then
      localPath := scriptData.URL;

    Self._SetDescriptionVisible(False);
    Self._SetDiscordCtaVisible(False);

    if panel <> nil then
    begin
      text := panel.GetChild('current_script_label');
      text.setCaption('local');
      text.SetFontColor($3DCF7A);

      text := panel.GetChild('latest_script_label');
      text.setCaption('rev.' + ToStr(Max(scriptData.Revision, 1)));
      text.SetFontColor($3DCF7A);
    end;

    if update <> nil then
    begin
      update.setCaption('Local');
      update.setEnabled(False);
    end;

    if open <> nil then
    begin
      open.setEnabled((localPath <> '') and FileExists(localPath));
      open.setCaption('Open script');
    end;

    panel := main.GetChild('script_panel');
    text := panel.GetChild('script_name_label');
    text.setCaption(scriptData.Name);

    text := panel.GetChild('script_category_label');
    text.setCaption('Local');
    text.SetFontColor($A89F90);
    text.setLeft(panel.getWidth() - text.GetTrueWidth() - TControl.AdjustToDPI(5));
    Exit;
  end;

  Self._SetDescriptionVisible(True);
  Self._SetDiscordCtaVisible(scriptData.Typ <> EScriptType.FREE);

  scriptFile := WaspUpdater.GetScriptFile(scriptData.ID);

  if panel <> nil then
  begin
    text := panel.GetChild('current_script_label');
    if scriptFile.Revision = 0 then
      text.setCaption('-')
    else
      text.setCaption('rev.' + ToStr(scriptFile.Revision));

    if scriptFile.Revision <> scriptData.Revision then
      text.SetFontColor($4C5DE8)
    else
      text.SetFontColor($3DCF7A);

    text := panel.GetChild('latest_script_label');
    text.setCaption('rev.' + ToStr(scriptData.Revision));

    if scriptFile.Revision <> scriptData.Revision then
      text.SetFontColor($4C5DE8)
    else
      text.SetFontColor($3DCF7A);
  end;

  if update <> nil then
  begin
    if (scriptData.Typ = EScriptType.PREMIUM_NO_SUB) or (scriptData.Typ = EScriptType.TESTING_NO_SUB) or (scriptData.Typ = EScriptType.FULL_NO_SUB) then
    begin
      update.setCaption('No License');
      update.setEnabled(False);
    end
    else
    begin
      update.setEnabled(True);
      case scriptFile.Revision of
        0: update.setCaption('Install');
        scriptData.Revision: update.setCaption('Re-install');
        else update.setCaption('Update');
      end;
    end;
  end;

  if open <> nil then
  begin
    open.setEnabled((scriptFile.Path <> '') and FileExists(scriptFile.Path));
    open.setCaption('Open script');
  end;

  panel := main.GetChild('script_panel');
  text := panel.GetChild('script_name_label');
  text.setCaption(scriptData.Name);

  text := panel.GetChild('script_category_label');
  case scriptData.Typ of
    EScriptType.PREMIUM:
    begin
      text.setCaption('Premium');
      text.SetFontColor($3DCF7A);
    end;
    EScriptType.PREMIUM_NO_SUB:
    begin
      text.setCaption('Premium - Locked');
      text.SetFontColor($3084B8);
    end;
    EScriptType.TESTING:
    begin
      text.setCaption('Testing');
      text.SetFontColor($3DCF7A);
    end;
    EScriptType.TESTING_NO_SUB:
    begin
      text.setCaption('Testing - Locked');
      text.SetFontColor($C8904A);
    end;
    EScriptType.FULL:
    begin
      text.setCaption('Full');
      text.SetFontColor($3DCF7A);
    end;
    EScriptType.FULL_NO_SUB:
    begin
      text.setCaption('Full - No sales');
      text.SetFontColor($4C5DE8);
    end;
    else
    begin
      text.setCaption('Free');
      text.SetFontColor($F2EDE4);
    end;
  end;
  text.setLeft(panel.getWidth() - text.GetTrueWidth() - TControl.AdjustToDPI(5));

  memo := panel.GetChild('script_content_memo');
  memo.setText(scriptData.Description);
end;

procedure TWaspForm._OnScriptOnKeyDown(sender: TObject; var key: Char);
var
  tmp: Char;
begin
  tmp := key;
  key := #0;

  case tmp of
    ' ':
    begin
      if not BashScriptClient.IsLocalSource() then
        Self._UpdateScript();
    end;
    #13:
      Self._OpenScript(sender);
  end;
end;

procedure TWaspForm.SetupVersionsPanel(parent: TPanel; top: Int32);
  type TWaspForm = TWaspForm;

  function TWaspForm._VersionsTitleLabel(parent: TPanel; name: String; left: Int32): TPanel;
  var
    textLabel: TLabel;
  begin
    Result.Create(parent);
    Result.setName(LowerCase(name) + '_version_title_panel');
    Result.setCaption('');
    Result.setWidth(TControl.AdjustToDPI(100));
    Result.setHeight(parent.GetHeight());
    Result.SetLeft(left);
    Result.setBevelWidth(0);
    Result.setColor($1A1814);

    textLabel.Create(Result);
    textLabel.setName(LowerCase(name) + '_srl_title_label');
    textLabel.setCaption(name + ' SRL-B:');
    textLabel.setLeft(TControl.AdjustToDPI(3));
    textLabel.SetFontSize(9);
    textLabel.SetFontColor($A89F90);
    textLabel.SetFontQuality(TFontQuality.fqCleartype);

    textLabel.Create(Result);
    textLabel.setName(LowerCase(name) + '_wl_title_label');
    textLabel.setCaption(name + ' BashLib:');
    textLabel.setLeft(TControl.AdjustToDPI(3));
    textLabel.SetTop(TControl.AdjustToDPI(20));
    textLabel.SetFontSize(9);
    textLabel.SetFontColor($A89F90);
    textLabel.SetFontQuality(TFontQuality.fqCleartype);

    textLabel.Create(Result);
    textLabel.setName(LowerCase(name) + '_script_title_label');
    textLabel.setCaption(name + ' Script:');
    textLabel.setLeft(TControl.AdjustToDPI(3));
    textLabel.SetTop(TControl.AdjustToDPI(40));
    textLabel.SetFontSize(9);
    textLabel.SetFontColor($A89F90);
    textLabel.SetFontQuality(TFontQuality.fqCleartype);
  end;

  function TWaspForm._VersionsLabel(parent: TPanel; name, srlt, wl: String; left: Int32): TPanel;
  var
    textLabel: TLabel;
  begin
    Result.Create(parent);
    Result.setName(name + '_version_panel');
    Result.setCaption('');
    if name = 'current' then
      Result.setWidth(TControl.AdjustToDPI(90))
    else
      Result.setWidth(TControl.AdjustToDPI(70));
    Result.setHeight(parent.GetHeight());
    Result.SetLeft(left);
    Result.setBevelWidth(0);
    Result.setColor($1A1814);

    textLabel.Create(Result);
    textLabel.setName(name + '_srl_label');
    if srlt = '' then
      textLabel.setCaption('Missing')
    else if srlt = 'failed' then
      textLabel.setCaption('Rate limited')
    else
      textLabel.setCaption('v.' + srlt);
    textLabel.setLeft(TControl.AdjustToDPI(3));
    textLabel.SetFontSize(9);
    if srlt <> GitHubClient.Packages.Latest.SRLT then
      textLabel.SetFontColor($4C5DE8)
    else
      textLabel.SetFontColor($3DCF7A);

    textLabel.Create(Result);
    textLabel.setName(name + '_wl_label');

    if wl = '' then
      textLabel.setCaption('Missing')
    else if wl = 'failed' then
      textLabel.setCaption('Rate limited')
    else
      textLabel.setCaption('v.' + wl);

    textLabel.setLeft(TControl.AdjustToDPI(3));
    textLabel.SetTop(TControl.AdjustToDPI(20));
    textLabel.SetFontSize(9);
    if wl <> GitHubClient.Packages.Latest.WaspLib then
      textLabel.SetFontColor($4C5DE8)
    else
      textLabel.SetFontColor($3DCF7A);

    textLabel.Create(Result);
    textLabel.setName(name + '_script_label');
    textLabel.setLeft(TControl.AdjustToDPI(3));
    textLabel.SetTop(TControl.AdjustToDPI(40));
    textLabel.SetFontSize(9);
    textLabel.SetFontColor($F2EDE4);
  end;

  function TWaspForm._VersionsControls(parent: TPanel; left: Int32): TPanel;
    type TWaspForm = TWaspForm;
    procedure TWaspForm._UpdateButton(sender: TObject);
    begin
      case TButton(sender).getName() of
        'update_srl_button':    {$IFNDEF DEVELOPER_MODE}Sync(@Self._UpdateSRL){$ENDIF};
        'update_wl_button':     {$IFNDEF DEVELOPER_MODE}Sync(@Self._UpdateWL){$ENDIF};
        'update_script_button': Self._UpdateScript();
      end;
    end;

  var
    button: TButton;
  begin
    Result.Create(parent);
    Result.setName('version_buttons_panel');
    Result.setCaption('');
    Result.SetLeft(left);
    Result.setWidth(TControl.AdjustToDPI(76));
    Result.setHeight(parent.GetHeight());
    Result.setBevelWidth(0);
    Result.setColor($1A1814);

    button.Create(Result);
    button.setName('update_srl_button');
    button.setLeft(TControl.AdjustToDPI(3));
    button.setHeight(TControl.AdjustToDPI(20));
    button.setWidth(TControl.AdjustToDPI(70));
    if GitHubClient.Packages.Current.SRLT <> GitHubClient.Packages.Latest.SRLT then
      button.setCaption('Update')
    else
      button.setCaption('Re-install');
    button.setOnClick(@Self._UpdateButton);

    button.Create(Result);
    button.setName('update_wl_button');
    button.setLeft(TControl.AdjustToDPI(3));
    button.SetTop(TControl.AdjustToDPI(20));
    button.setHeight(TControl.AdjustToDPI(20));
    button.setWidth(TControl.AdjustToDPI(70));
    if GitHubClient.Packages.Current.WaspLib <> GitHubClient.Packages.Latest.WaspLib then
      button.setCaption('Update')
    else
      button.setCaption('Re-install');
    button.setOnClick(@Self._UpdateButton);

    button.Create(Result);
    button.setName('update_script_button');
    button.setLeft(TControl.AdjustToDPI(3));
    button.SetTop(TControl.AdjustToDPI(40));
    button.setHeight(TControl.AdjustToDPI(20));
    button.setWidth(TControl.AdjustToDPI(70));
    button.setCaption('Install');
    button.setOnClick(@Self._UpdateButton);
  end;

  var
  panel, tmp: TPanel;
  w: Int32;
begin
  panel.Create(parent);
  panel.setName('version_panel');
  panel.setCaption('');
  panel.setAlign(TAlign.alCustom);
  panel.setBorderStyle(TFormBorderStyle.bsNone);
  panel.setBevelWidth(0);
  panel.SetTop(top);
  panel.setHeight(TControl.AdjustToDPI(62));
  panel.setColor($1A1814);

  tmp := Self._VersionsTitleLabel(panel, 'Current', 0);
  w := tmp.getWidth();
  tmp := Self._VersionsLabel(panel, 'current', GitHubClient.Packages.Current.SRLT, GitHubClient.Packages.Current.WaspLib, w);
  w += tmp.getWidth();

  tmp := Self._VersionsTitleLabel(panel, 'Latest', w);
  w += tmp.getWidth();
  tmp := Self._VersionsLabel(panel, 'latest', GitHubClient.Packages.Latest.SRLT, GitHubClient.Packages.Latest.WaspLib, w);
  w += tmp.getWidth();

  tmp := Self._VersionsControls(panel, w);
  w += tmp.getWidth();

  panel.setWidth(w + TControl.AdjustToDPI(8));
  panel.setLeft(Self.Size.X - TControl.AdjustToDPI(24) - panel.getWidth());
end;

procedure TWaspForm.SetupColorLegend(parent: TPanel);
var
  panel, swatch: TPanel;
  text: TLabel;
  versionPanel: TPanel;
  i, y, rowH, sw, legendW: Int32;
  colors: array[0..4] of TColor;
  labels: array[0..4] of String;
begin
  colors[0] := $F2EDE4; labels[0] := 'Free';
  colors[1] := $3DCF7A; labels[1] := 'Unlocked';
  colors[2] := $3084B8; labels[2] := 'Premium';
  colors[3] := $C8904A; labels[3] := 'Testing';
  colors[4] := $4C5DE8; labels[4] := 'Full (No Sales)';

  rowH := TControl.AdjustToDPI(16);
  sw := TControl.AdjustToDPI(10);
  legendW := TControl.AdjustToDPI(120);

  panel.Create(parent);
  panel.setName('color_legend_panel');
  panel.setCaption('');
  panel.setBevelWidth(0);
  panel.setColor($1A1814);
  panel.setWidth(legendW);
  panel.setHeight(5 * rowH);

  versionPanel := parent.GetChild('version_panel');
  if versionPanel <> nil then
  begin
    panel.SetTop(versionPanel.GetTop() + versionPanel.getHeight() + TControl.AdjustToDPI(15));
    panel.SetLeft(versionPanel.GetLeft() + versionPanel.getWidth() - legendW + TControl.AdjustToDPI(25));
  end
  else
  begin
    panel.SetTop(TControl.AdjustToDPI(80));
    panel.SetLeft(Self.Size.X - TControl.AdjustToDPI(24) - legendW + TControl.AdjustToDPI(20));
  end;

  y := 0;
  for i := 0 to 4 do
  begin
    swatch.Create(panel);
    swatch.setName('color_legend_swatch_' + ToStr(i));
    swatch.setCaption('');
    swatch.setBevelWidth(0);
    swatch.setColor(colors[i]);
    swatch.SetLeft(0);
    swatch.SetTop(y + ((rowH - sw) div 2));
    swatch.setWidth(sw);
    swatch.setHeight(sw);

    text.Create(panel);
    text.setName('color_legend_label_' + ToStr(i));
    text.setCaption(labels[i]);
    text.SetFontSize(8);
    text.SetFontColor(colors[i]);
    text.SetFontStyle([TFontStyle.fsBold]);
    text.SetLeft(sw + TControl.AdjustToDPI(6));
    text.SetTop(y);
    y += rowH;
  end;

  panel.setHeight(y);
end;

procedure TWaspForm.SetupScriptPanel(parent: TPanel; topLeft: TPoint);
var
  panel, memoInnerPanel, memoOutterPanel: TPanel;
  text: TLabel;
  memo: TMemo;
begin
  panel.Create(parent);
  panel.setName('script_panel');
  panel.setCaption('');
  panel.SetLeft(topLeft.X);
  panel.SetTop(topLeft.Y);
  panel.setWidth(Self.Size.X - topLeft.X - TControl.AdjustToDPI(24));
  panel.setHeight(Self.Size.Y - topLeft.Y - TControl.AdjustToDPI(100));
  panel.setBevelWidth(0);
  panel.setColor($1A1814);

  text.Create(panel);
  text.setName('script_name_label');
  text.SetFontSize(14);
  text.SetFontStyle([TFontStyle.fsBold]);
  text.SetFontColor($F2EDE4);
  text.setLeft(TControl.AdjustToDPI(4));
  text.SetTop(TControl.AdjustToDPI(4));

  text.Create(panel);
  text.setName('script_category_label');
  text.SetFontSize(10);
  text.SetFontColor($D4A017);
  text.setLeft(-TControl.AdjustToDPI(5));
  text.SetTop(TControl.AdjustToDPI(8));

  text.Create(panel);
  text.setName('script_discord_cta_label');
  text.setCaption('Click here to join the Discord to see availability');
  text.setLeft(TControl.AdjustToDPI(4));
  text.SetTop(TControl.AdjustToDPI(28));
  text.SetFontSize(9);
  text.SetFontColor($D4A017);
  text.setHint('Open the B.A.S.H Discord');
  text.setShowHint(True);
  text.setCursor(crHandPoint);
  text.setOnClick(@OpenBashDiscord);
  text.setVisible(False);

  memoOutterPanel.Create(panel);
  memoOutterPanel.setName('script_omemo_panel');
  memoOutterPanel.setCaption('');
  memoOutterPanel.SetTop(TControl.AdjustToDPI(36));
  memoOutterPanel.setWidth(panel.getWidth());
  memoOutterPanel.setHeight(panel.getHeight() - memoOutterPanel.GetTop());
  memoOutterPanel.setBevelWidth(0);
  memoOutterPanel.setColor($3A342C);

  memoInnerPanel.Create(memoOutterPanel);
  memoInnerPanel.setName('script_imemo_panel');
  memoInnerPanel.setCaption('');
  memoInnerPanel.SetTop(TControl.AdjustToDPI(1));
  memoInnerPanel.SetLeft(TControl.AdjustToDPI(1));
  memoInnerPanel.setWidth(memoOutterPanel.getWidth() - TControl.AdjustToDPI(2));
  memoInnerPanel.setHeight(memoOutterPanel.getHeight() - TControl.AdjustToDPI(2));
  memoInnerPanel.setBevelWidth(0);
  memoInnerPanel.setColor($24201C);

  memo.Create(memoInnerPanel);
  memo.setName('script_content_memo');
  memo.setLeft(-TControl.AdjustToDPI(1));
  memo.SetTop(-TControl.AdjustToDPI(1));
  memo.setWidth(memoInnerPanel.getWidth() + TControl.AdjustToDPI(2));
  memo.setHeight(memoInnerPanel.getHeight() + TControl.AdjustToDPI(2));
  memo.setColor($24201C);
  memo.SetFontColor($F2EDE4);
  memo.setScrollBars(TScrollStyle.ssAutoBoth);
  memo.setReadOnly(True);
  memo.setHideSelection(True);
  memo.setWordWrap(True);
end;

procedure TWaspForm.OnDrawItem(control: TWinControl; idx: Integer; rect: TRect; state: TOwnerDrawState);
var
  listbox: TListBox;
  color, fColor: TColor;
  text: String;
  textH, textY: Int32;
begin
  listbox := control;
  if listbox.getItems().getCount() = 0 then Exit;
  if idx = listbox.getItemIndex() then color := $3A342C
  else if idx mod 2 = 0 then color := $24201C
  else color := $1A1814;

  fColor := $F2EDE4;
  if (idx >= 0) and (idx <= High(Self.VisibleScripts)) then
  begin
    case Self.VisibleScripts[idx].Typ of
      EScriptType.PREMIUM,
      EScriptType.TESTING,
      EScriptType.FULL: fColor := $3DCF7A;
      EScriptType.PREMIUM_NO_SUB: fColor := $3084B8;
      EScriptType.TESTING_NO_SUB: fColor := $C8904A;
      EScriptType.FULL_NO_SUB: fColor := $4C5DE8;
    end;
  end;

  listbox.getCanvas().getBrush().setColor(color);
  listbox.getCanvas().FillRect(rect.Left, rect.Top, rect.Right, rect.Bottom);

  listbox.getCanvas().GetFont().setColor(fColor);
  listbox.getCanvas().getFont().setStyle([TFontStyle.fsBold]);
  text := listbox.getItems().getStrings(idx);
  textH := listbox.getCanvas().TextHeight(text);
  textY := rect.Top + ((rect.Bottom - rect.Top) - textH) div 2;
  if textY < rect.Top then
    textY := rect.Top;
  listbox.getCanvas().TextRect(rect, TControl.AdjustToDPI(6), textY, text);
end;

procedure TWaspForm.SetupScriptsPanel(parent: TPanel);
  type TWaspForm = TWaspForm;

  procedure TWaspForm._OnBrandingClick(sender: TObject);
  begin
    OpenBashDiscord(sender);
  end;

var
  panel, accentBar, sourcePanel, licensePanel, activityPanel, activityCell, categoryPanel: TPanel;
  logo, activityIcon: TImage;
  branding, subtitle, discordLink, launcherRev, bashLabel, localLabel, licenseStatus, activityCaption: TLabel;
  button, saveBtn, clearBtn, categoryBtn: TButton;
  scriptsList: TLabeledDarkListBox;
  licenseEdit: TLabeledEdit;
  bashRadio, localRadio: TRadioButton;
  listTop, footerTop, colGap, logoSize, textLeft, headerBottom, radioTop: Int32;
  logoPath, iconPath: String;
  actIds, catIds, catLabels: TStringArray;
  ai, ax, aw, ah, gap, iconSize, iconPad, catW: Int32;
begin
  panel.Create(parent);
  panel.setName('scripts_panel');
  panel.setCaption('');
  panel.setWidth(Self.Size.X);
  panel.setHeight(Self.Size.Y);
  panel.setBevelWidth(0);
  panel.setColor($1A1814);

  Self.ActivityFilter := 'all';
  Self.ActivityCategory := 'all';
