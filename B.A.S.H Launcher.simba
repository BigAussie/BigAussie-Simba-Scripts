{$IFNDEF SRL_TIME_INCLUDED}
{$DEFINE SRL_TIME_INCLUDED}

function TSRL.TimeStamp(): String;
var
  Time: Int64;
  Hours, Mins, Secs, Millis: Int32;
begin
  Time := GetTimeRunning();

  Hours  := Time div 3600000;
  Time   := Time mod 3600000;
  Mins   := Time div 60000;
  Time   := Time mod 60000;
  Secs   := Time div 1000;
  Millis := Time mod 1000;

  Result := Format('[%.2d:%.2d:%.2d:%.3d]', [Hours, Mins, Secs, Millis]);
end;

{$IFNDEF SRL_FILE_INCLUDED}
{$DEFINE SRL_FILE_INCLUDED}

function DeleteFiles(const directory: String; skip: TStringArray = []): Boolean;
  function _SkipFile(dir: String): Boolean;
  var
    s: String;
  begin
    for s in skip do
      if dir.Contains(s) then
        Exit(True);
  end;

var
  f: String;
begin
  for f in FindFiles(directory, True) do
  begin
    if _SkipFile(f) then
      Continue;

    if not DeleteFile(f) then
      Exit;
  end;

  Result := True;
end;

function DeleteSubDirectories(const directory: String; deleteRoot: Boolean; skip: TStringArray = []): Boolean;

  function _SkipDirectory(dir: String): Boolean;
  var
    s: String;
  begin
    for s in skip do
      if dir.Contains(s) then
        Exit(True);
  end;

  function _GetParent(dir: String): String;
  var
    strings: TStringArray;
  begin
    strings := dir.Explode(DirectorySeparator);
    SetLength(strings, High(strings));
    Result := strings.Merge(DirectorySeparator);
  end;

var
  directories, parents: TStringArray;
  i: Int32;
begin
  directories := FindDirectories(directory, True);

  while directories <> [] do
  begin
    for i := High(directories) downto 0 do
    begin
      if _SkipDirectory(directories[i]) then
      begin
        parents += _GetParent(directories[i]);
        Delete(directories, i, 1);
        deleteRoot := False;
        Continue;
      end;

      if not parents.Contains(directories[i]) and not DeleteDirectory(directories[i], False) then
        Exit;
      Delete(directories, i, 1);
    end;
  end;

  Result := not deleteRoot or DeleteDirectory(directory, False);
end;

function RMDir(const directory: String; deleteRoot: Boolean; skip: TStringArray = []): Boolean;
begin
  if not DeleteFiles(directory, skip) then
    Exit;

  Result := DeleteSubDirectories(directory, deleteRoot, skip);
end;

function RMDir(path: String): Boolean; overload;
begin
  Result := RMDir(path, True, []);
end;

{$IFNDEF SRL_STRING_INCLUDED}
{$DEFINE SRL_STRING_INCLUDED}

const
  STR_WHITESPACE = #9#10#11#12#13#32;

function String.Contains(subString: String): Boolean; constref;
begin
  Result := System.Pos(subString, Self) > 0;
end;

function String.StartsWith(Prefix: String): Boolean; constref;
begin
  Result := System.Pos(Prefix, Self) = 1;
end;

function String.EndsWith(Suffix: String): Boolean; constref;
var
  i,l: Int32;
begin
  if Length(Suffix) > Length(Self) then
    Exit(False);
  Result := True;
  l := Length(Self);
  for i:=1 to Length(Suffix) do
    if (Suffix[i] <> Self[l-Length(Suffix)+i]) then
      Exit(False);
end;

function String.After(SubStr: String): String; constref;
var
  p: UInt32;
begin
  p := System.Pos(SubStr, Self);
  if (p = 0) then Exit(Self);
  Inc(p, Length(SubStr));
  Result := Copy(Self, p, Length(Self) - p + 1);
end;

function String.Before(SubStr: String): String; constref;
var
  p: UInt32;
begin
  p := System.Pos(SubStr, Self);
  if (p = 0) then Exit(Self);
  Result := Copy(Self, 1, p - 1);
end;

function String.Replace(SubStr, ReplaceStr: String; Flags: TReplaceFlags=[rfReplaceAll]): String; constref;
begin
  Result := StringReplace(Self, SubStr, ReplaceStr, Flags);
end;

function String.ReplaceAll(SubStrReplaceStrArray: array of TStringArray; Flags: TReplaceFlags=[rfReplaceAll]): String; constref;
var
  i: Int32;
begin
  Result := Self;
  for i := 0 to High(SubStrReplaceStrArray) do
  begin
    if Length(SubStrReplaceStrArray[i]) <> 2 then
      raise 'SubStrReplaceStrArray children should have only 2 elements, a SubStr and a ReplaceStr.';

    Result := StringReplace(Result, SubStrReplaceStrArray[i,0], SubStrReplaceStrArray[i,1], Flags);
  end;
end;

function String.Split(delimiter: String): TStringArray; constref;
begin
  Result := System.Explode(delimiter, Self);
end;

function String.Explode(Delimiter: String): TStringArray; constref;
begin
  Result := System.Explode(Delimiter, Self);
end;

function String.Trim(chars:String = STR_WHITESPACE): String; constref;
var Lo,Hi: UInt32 = 1;
begin
  Hi:=Length(Self);
  while (Lo <= Hi) and (System.Pos(Self[Lo],Chars) <> 0) do Inc(Lo);
  while (Hi >= 1)  and (System.Pos(Self[Hi],Chars) <> 0) do Dec(Hi);
  Result := Copy(Self, Lo, Hi-Lo+1);
end;

{$IFNDEF SRL_STRINGARRAY_INCLUDED}
{$DEFINE SRL_STRINGARRAY_INCLUDED}

function TStringArray.Find(const value: String): Int32; constref;
begin
  for Result := 0 to High(Self) do
    if value = Self[Result] then
      Exit;
  Result := -1;
end;

function TStringArray.Contains(const value: String): Boolean; constref;
begin
  Result := Self.Find(value) > -1;
end;

function TStringArray.Merge(glue: String = ''): String; constref;
var
  i: Int32;
begin
  if Length(Self) = 0 then Exit;

  Result := Self[0];
  for i := 1 to High(Self) do
    Result += glue + Self[i];
end;

{$IFNDEF WS_UTILS_INCLUDED}

{$DEFINE WS_UTILS_INCLUDED}

procedure TerminateScript(reason: String); overload;
begin
  WriteLn('Terminating: ' + reason);
  TerminateScript();
end;

procedure DebugLn(name, text: String);
begin
  WriteLn(SRL.TimeStamp() + ':[' + name + ']: ' + text);
end;

function TJSONArray.High(): Int32;
begin
  if Self = nil then
    Exit(-1);
  Result := Self.length()-1;
end;

{$IFNDEF WS_ASYNC_INCLUDED}
{$DEFINE WS_ASYNC_INCLUDED}

type
  EMonitorState = (NONE, DOWNLOAD, UNZIP, CLEAN);

  TMonitor = record
    Package: String;
    CurrentFile: String;
    State: EMonitorState;
    IsSetup: Boolean;
    StartedAt: UInt64;

    Caption: TLabel;
    Button: TButton;
    Timer: TTimer;
  end;

  TWaspAsync = record
    Path: String;
  end;

procedure TWaspAsync.Write(name, content: String);
begin
  if not WriteFileContents(Self.Path + name, content, False) then
    TerminateScript('WaspAsync: Failed to write async file: ' + name);
end;

procedure TWaspAsync.Run(name: String; params: TStringArray);
begin
  if not name.EndsWith('.simba') then
    name += '.simba';
  RunScript(Self.Path + name, params);
end;

function TWaspAsync.GetDownloaderContent(): String;
begin
  Result += "var" + LineEnding;
  Result += "  timeout: TTimer;" + LineEnding;
  Result += "  http: Int32;" + LineEnding;
  Result += "  url, pkg, dest, failPath, donePath: String;" + LineEnding;
  Result += "  code: Int32;" + LineEnding;
  Result += "  t: UInt64;" + LineEnding;
  Result += "  ok: Boolean;" + LineEnding + LineEnding;
  Result += "procedure OnTimer({$H-}sender: TObject);{$H+}" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  WriteLn('[AsyncDownloader]: Still downloading ', pkg, '...');" + LineEnding + LineEnding;
  Result += "  if GetTickCount() > t then" + LineEnding;
  Result += "  begin" + LineEnding;
  Result += "    WriteLn('[AsyncDownloader]: Download is taking a long time. If rate limited, wait ~1 hour and retry.');" + LineEnding;
  Result += "    t := GetTickCount() + 120000;" + LineEnding;
  Result += "  end;" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "procedure Free();" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  timeout.setEnabled(False);" + LineEnding;
  Result += "  timeout.Free();" + LineEnding;
  Result += "  FreeHTTPClient(http);" + LineEnding;
  Result += "  if ok then" + LineEnding;
  Result += "    CloseFile(CreateFile(donePath))" + LineEnding;
  Result += "  else" + LineEnding;
  Result += "    CloseFile(CreateFile(failPath));" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "procedure RunTimer();" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  timeout.setOnTimer(@OnTimer);" + LineEnding;
  Result += "  timeout.setEnabled(True);" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  url := GetProcessParameter('url');" + LineEnding;
  Result += "  pkg := GetProcessParameter('pkg');" + LineEnding;
  Result += "  dest := GetProcessParameter('destination');" + LineEnding;
  Result += "  donePath := {$MACRO CURRENT_DIRECTORY} + 'downloader-' + LowerCase(pkg) + '.done';" + LineEnding;
  Result += "  failPath := {$MACRO CURRENT_DIRECTORY} + 'downloader-' + LowerCase(pkg) + '.fail';" + LineEnding;
  Result += "  ok := False;" + LineEnding + LineEnding;
  Result += "  if FileExists(donePath) then DeleteFile(donePath);" + LineEnding;
  Result += "  if FileExists(failPath) then DeleteFile(failPath);" + LineEnding + LineEnding;
  Result += "  if (url = '') or (dest = '') then" + LineEnding;
  Result += "  begin" + LineEnding;
  Result += "    WriteLn('[AsyncDownloader]: Missing download URL or destination (often rate-limited version lookup).');" + LineEnding;
  Result += "    CloseFile(CreateFile(failPath));" + LineEnding;
  Result += "    TerminateScript();" + LineEnding;
  Result += "  end;" + LineEnding + LineEnding;
  Result += "  timeout.Init(nil);" + LineEnding;
  Result += "  timeout.SetName('downloader_timeout');" + LineEnding;
  Result += "  timeout.SetInterval(20000);" + LineEnding;
  Result += "  http := InitializeHTTPClient(True);" + LineEnding;
  Result += "  SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');" + LineEnding;
  Result += "  Sync(@RunTimer);" + LineEnding;
  Result += "  AddOnTerminate(@Free);" + LineEnding + LineEnding;
  Result += "  WriteLn('[AsyncDownloader]: Downloading ', pkg, '...');" + LineEnding;
  Result += "  t := GetTickCount() + 120000;" + LineEnding + LineEnding;
  Result += "  try" + LineEnding;
  Result += "    code := GetHTTPPageEx(http, url, dest);" + LineEnding;
  Result += "    if code = 200 then" + LineEnding;
  Result += "    begin" + LineEnding;
  Result += "      ok := True;" + LineEnding;
  Result += "      WriteLn('[AsyncDownloader]: ' + pkg + ' downloaded.');" + LineEnding;
  Result += "    end" + LineEnding;
  Result += "    else if (code = 403) or (code = 429) then" + LineEnding;
  Result += "      WriteLn('[AsyncDownloader]: Rate limited (HTTP ', code, '). Wait about an hour, then retry.')" + LineEnding;
  Result += "    else" + LineEnding;
  Result += "      WriteLn('[AsyncDownloader]: Failed to download (HTTP ', code, '): ' + url);" + LineEnding;
  Result += "  except" + LineEnding;
  Result += "    WriteLn('[AsyncDownloader]: Error: ', GetExceptionMessage());" + LineEnding;
  Result += "  end;" + LineEnding;
  Result += "end;" + LineEnding;
end;

function TWaspAsync.GetUnzipperContent(): String;
begin
  Result += "var" + LineEnding;
  Result += "  path, name: String;" + LineEnding + LineEnding;
  Result += "procedure Free();" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  CloseFile(CreateFile({$MACRO CURRENT_DIRECTORY} + 'unzipper-' + LowerCase(name) + '.done'));" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  path := GetProcessParameter('path');" + LineEnding;
  Result += "  name := GetProcessParameter('name');" + LineEnding + LineEnding;
  Result += "  if FileExists({$MACRO CURRENT_DIRECTORY} + 'downloader-' + LowerCase(name) + '.done') then" + LineEnding;
  Result += "    DeleteFile({$MACRO CURRENT_DIRECTORY} + 'downloader-' + LowerCase(name) + '.done');" + LineEnding + LineEnding;
  Result += "  AddOnTerminate(@Free);" + LineEnding + LineEnding;
  Result += "  WriteLn('[AsyncUnzipper]: Unzipping ', name, ', this might take a while.');" + LineEnding + LineEnding;
  Result += "  try" + LineEnding;
  Result += "    UnZipFile(path + name + '.zip', path + name);" + LineEnding;
  Result += "    DeleteFile(path + name + '.zip');" + LineEnding;
  Result += "  except" + LineEnding;
  Result += "    WriteLn('[AsyncUnzipper]: Error: ', GetExceptionMessage());" + LineEnding;
  Result += "  end;" + LineEnding;
  Result += "end;" + LineEnding;
end;

function TWaspAsync.GetMoverContent(): String;
begin
  Result += "const" + LineEnding;
  Result += "  SEP = DirectorySeparator;" + LineEnding + LineEnding;
  Result += "procedure TerminateScript(reason: String); overload;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  WriteLn('[AsyncMover]: Terminating: ' + reason);" + LineEnding;
  Result += "  TerminateScript();" + LineEnding;
  Result += "end;" + LineEnding + LineEnding + LineEnding;
  Result += "function TStringArray.Find(const value: String): Integer; constref;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  for Result := 0 to High(Self) do" + LineEnding;
  Result += "    if value = Self[Result] then" + LineEnding;
  Result += "      Exit;" + LineEnding;
  Result += "  Result := -1;" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "function TStringArray.Contains(const value: String): Boolean; constref;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  Result := Self.Find(value) > -1;" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "function TStringArray.Merge(glue:String=''): String; constref;" + LineEnding;
  Result += "var" + LineEnding;
  Result += "  i:Int32;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  if Length(Self) = 0 then" + LineEnding;
  Result += "    Exit();" + LineEnding + LineEnding;
  Result += "  Result := Self[0];" + LineEnding;
  Result += "  for i:=1 to High(Self) do" + LineEnding;
  Result += "    Result += glue + Self[i];" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "function BackupFile(filePath: String): Boolean;" + LineEnding;
  Result += "var" + LineEnding;
  Result += "  f: Int32;" + LineEnding;
  Result += "  contents: String;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  f := OpenFile(filePath, False);" + LineEnding;
  Result += "  if not ReadFileString(f, contents, FileSize(f)) then" + LineEnding;
  Result += "    Exit;" + LineEnding + LineEnding;
  Result += "  CloseFile(f);" + LineEnding;
  Result += "  Result := WriteFileContents(filePath + '.bak', contents, False);" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "function RestoreFile(filePath: String): Boolean;" + LineEnding;
  Result += "var" + LineEnding;
  Result += "  f: Int32;" + LineEnding;
  Result += "  contents: String;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  f := OpenFile(filePath + '.bak', False);" + LineEnding;
  Result += "  if not ReadFileString(f, contents, FileSize(f)) then" + LineEnding;
  Result += "    Exit;" + LineEnding + LineEnding;
  Result += "  CloseFile(f);" + LineEnding;
  Result += "  Result := WriteFileContents(filePath, contents, False);" + LineEnding;
  Result += "  DeleteFile(filePath + '.bak');" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "function DirectoryIsEmpty(const directory: String): Boolean;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  Result := (FindFiles(directory, False) = []) and (FindDirectories(directory, False) = []);" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "function DeleteFiles(const directory: String; skip: TStringArray = []): Boolean;" + LineEnding;
  Result += "  function _SkipFile(dir: String): Boolean;" + LineEnding;
  Result += "  var" + LineEnding;
  Result += "    s: String;" + LineEnding;
  Result += "  begin" + LineEnding;
  Result += "    for s in skip do" + LineEnding;
  Result += "      if Pos(s, dir) > 0 then" + LineEnding;
  Result += "        Exit(True);" + LineEnding;
  Result += "  end;" + LineEnding + LineEnding;
  Result += "var" + LineEnding;
  Result += "  f: String;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  for f in FindFiles(directory, True) do" + LineEnding;
  Result += "  begin" + LineEnding;
  Result += "    if _SkipFile(f) then" + LineEnding;
  Result += "      Continue;" + LineEnding + LineEnding;
  Result += "    if not DeleteFile(f) then" + LineEnding;
  Result += "      Exit;" + LineEnding;
  Result += "  end;" + LineEnding + LineEnding;
  Result += "  Result := True;" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "function DeleteSubDirectories(const directory: String; deleteRoot: Boolean; skip: TStringArray = []): Boolean;" + LineEnding + LineEnding;
  Result += "  function _SkipDirectory(dir: String): Boolean;" + LineEnding;
  Result += "  var" + LineEnding;
  Result += "    s: String;" + LineEnding;
  Result += "  begin" + LineEnding;
  Result += "    for s in skip do" + LineEnding;
  Result += "      if Pos(s, dir) > 0 then" + LineEnding;
  Result += "        Exit(True);" + LineEnding;
  Result += "  end;" + LineEnding + LineEnding;
  Result += "  function _GetParent(dir: String): String;" + LineEnding;
  Result += "  var" + LineEnding;
  Result += "    strings: TStringArray;" + LineEnding;
  Result += "  begin" + LineEnding;
  Result += "    strings := Explode(DirectorySeparator, dir);" + LineEnding;
  Result += "    SetLength(strings, High(strings));" + LineEnding;
  Result += "    Result := strings.Merge(DirectorySeparator);" + LineEnding;
  Result += "  end;" + LineEnding + LineEnding;
  Result += "var" + LineEnding;
  Result += "  directories, parents: TStringArray;" + LineEnding;
  Result += "  i: Int32;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  directories := FindDirectories(directory, True);" + LineEnding + LineEnding;
  Result += "  while directories <> [] do" + LineEnding;
  Result += "  begin" + LineEnding;
  Result += "    for i := High(directories) downto 0 do" + LineEnding;
  Result += "    begin" + LineEnding;
  Result += "      if _SkipDirectory(directories[i]) then" + LineEnding;
  Result += "      begin" + LineEnding;
  Result += "        parents += _GetParent(directories[i]);" + LineEnding;
  Result += "        Delete(directories, i, 1);" + LineEnding;
  Result += "        deleteRoot := False;" + LineEnding;
  Result += "        Continue;" + LineEnding;
  Result += "      end;" + LineEnding + LineEnding;
  Result += "      if not parents.Contains(directories[i]) and not DeleteDirectory(directories[i], False) then" + LineEnding;
  Result += "        Exit;" + LineEnding;
  Result += "      Delete(directories, i, 1);" + LineEnding;
  Result += "    end;" + LineEnding;
  Result += "  end;" + LineEnding + LineEnding;
  Result += "  Result := not deleteRoot or DeleteDirectory(directory, False);" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "function RMDir(const directory: String; deleteRoot: Boolean; skip: TStringArray = []): Boolean;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  if not DeleteFiles(directory, skip) then" + LineEnding;
  Result += "    Exit;" + LineEnding + LineEnding;
  Result += "  Result := DeleteSubDirectories(directory, deleteRoot, skip);" + LineEnding;
  Result += "end;" + LineEnding + LineEnding + LineEnding;
  Result += "function IsFileLocked(path: String): Boolean;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  if not FileExists(path) then" + LineEnding;
  Result += "    Exit;" + LineEnding + LineEnding;
  Result += "  if not BackupFile(path) then" + LineEnding;
  Result += "    TerminateScript('Failed to backup file: ' + path);" + LineEnding + LineEnding;
  Result += "  Result := not DeleteFile(path);" + LineEnding + LineEnding;
  Result += "  if Result then" + LineEnding;
  Result += "    DeleteFile(path + '.bak')" + LineEnding;
  Result += "  else if not RestoreFile(path) then" + LineEnding;
  Result += "    TerminateScript('Failed to restore file: ' + path);" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "function FindLockedPlugins(): TStringArray;" + LineEnding;
  Result += "const" + LineEnding;
  Result += "  PATHS = [" + LineEnding;
  Result += "    IncludePath + 'SRL'   + SEP + 'plugins' + SEP + 'libremoteinput' + SEP," + LineEnding;
  Result += "    IncludePath + 'SRL-T' + SEP + 'plugins' + SEP + 'libremoteinput' + SEP" + LineEnding;
  Result += "  ];" + LineEnding;
  Result += "var" + LineEnding;
  Result += "  path, plugin: String;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  for path in PATHS do" + LineEnding;
  Result += "    for plugin in FindFiles(path, False) do" + LineEnding;
  Result += "      if IsFileLocked(plugin) then" + LineEnding;
  Result += "        Result += plugin;" + LineEnding;
  Result += "end;" + LineEnding + LineEnding + LineEnding;
  Result += "procedure KillWindowByClass(name: String);" + LineEnding;
  Result += "var" + LineEnding;
  Result += "  window: TOSWindow;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  for window in GetWindows().GetByClass(name) do" + LineEnding;
  Result += "    window.Kill();" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "procedure KillSimbas();" + LineEnding;
  Result += "var" + LineEnding;
  Result += "  windows, simbas: TOSWindowArray;" + LineEnding;
  Result += "  win: TOSWindow;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  windows := GetWindows();" + LineEnding;
  Result += "  simbas := windows.GetByTitleAndClass('Output,File Browser,Editor,Function List', 'Window');" + LineEnding + LineEnding;
  Result += "  if MessageDlg('Close Simba', 'Simba needs to be restarted.'," + LineEnding;
  Result += "     TMsgDlgType.mtConfirmation, [mbOK, mbAbort]) = 3 then" + LineEnding;
  Result += "    TerminateScript('You need to close all Simba windows to update SRL.');" + LineEnding + LineEnding;
  Result += "  for win in simbas do" + LineEnding;
  Result += "    win.Kill();" + LineEnding + LineEnding;
  Result += "  TerminateScript();" + LineEnding;
  Result += "end;" + LineEnding + LineEnding + LineEnding;
  Result += "procedure UnlockPlugins();" + LineEnding;
  Result += "var" + LineEnding;
  Result += "  locked: TStringArray;" + LineEnding;
  Result += "  plugin: String;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  locked := FindLockedPlugins();" + LineEnding;
  Result += "  if locked = [] then" + LineEnding;
  Result += "    Exit;" + LineEnding + LineEnding;
  Result += "  if MessageDlg('Close RuneScape', 'RS Clients need to be closed to update this package.'," + LineEnding;
  Result += "     TMsgDlgType.mtConfirmation, [mbOK, mbAbort]) = 3 then" + LineEnding;
  Result += "    TerminateScript('You need to close your RS Clients to update SRL.');" + LineEnding + LineEnding;
  Result += "  KillWindowByClass('SunAwtCanvas');" + LineEnding + LineEnding;
  Result += "  for plugin in locked do" + LineEnding;
  Result += "    if IsFileLocked(plugin) then" + LineEnding;
  Result += "    begin" + LineEnding;
  Result += "      KillWindowByClass('Jagex Launcher');" + LineEnding;
  Result += "      Break;" + LineEnding;
  Result += "    end;" + LineEnding + LineEnding;
  Result += "  for plugin in locked do" + LineEnding;
  Result += "    if IsFileLocked(plugin) then" + LineEnding;
  Result += "    begin" + LineEnding;
  Result += "      KillSimbas();" + LineEnding;
  Result += "      Break;" + LineEnding;
  Result += "    end;" + LineEnding;
  Result += "end;" + LineEnding + LineEnding + LineEnding;
  Result += "function GetInstallDir(pkg: String): String;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  case LowerCase(pkg) of" + LineEnding;
  Result += "    'srl-t', 'srlt', 'srl': Result := 'SRL-T';" + LineEnding;
  Result += "    'wasplib', 'wl': Result := 'WaspLib';" + LineEnding;
  Result += "    else Result := pkg;" + LineEnding;
  Result += "  end;" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "procedure MoveFiles(origin, pkg: String);" + LineEnding;
  Result += "var" + LineEnding;
  Result += "  paths, files: TStringArray;" + LineEnding;
  Result += "  path, f, fPath, destination: String;" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  paths := GetDirectories(origin + pkg + SEP);" + LineEnding;
  Result += "  if Length(paths) <> 1 then" + LineEnding;
  Result += "    TerminateScript('The ' + pkg + ' download is empty or has unexpected things inside.');" + LineEnding + LineEnding;
  Result += "  destination := IncludePath + GetInstallDir(pkg) + SEP;" + LineEnding;
  Result += "  if DirectoryExists(destination) and not RMDir(destination, True, ['.git', 'overrides.simba']) then" + LineEnding;
  Result += "    TerminateScript('Failed to delete old ' + GetInstallDir(pkg) + ' library');" + LineEnding;
  Result += "  if not ForceDirectories(destination) then" + LineEnding;
  Result += "    TerminateScript('Failed to create path: ' + destination);" + LineEnding + LineEnding;
  Result += "  path := origin + pkg + SEP + paths[0] + SEP;" + LineEnding;
  Result += "  files := FindFiles(path, True);" + LineEnding + LineEnding;
  Result += "  for f in files do" + LineEnding;
  Result += "  begin" + LineEnding;
  Result += "    fPath := Replace(f, path, '', [rfReplaceAll]);" + LineEnding;
  Result += "    if Pos('.git', fPath) > 0 then" + LineEnding;
  Result += "      Continue;" + LineEnding + LineEnding;
  Result += "    if Pos('overrides.simba', fPath) > 0 then" + LineEnding;
  Result += "      Continue;" + LineEnding + LineEnding;
  Result += "    if not ForceDirectories(destination + ExtractFilePath(fPath)) then" + LineEnding;
  Result += "      TerminateScript('Failed to create path: ' + destination + ExtractFilePath(fPath));" + LineEnding + LineEnding;
  Result += "    if not CopyFile(f, destination + fPath, False) then" + LineEnding;
  Result += "      TerminateScript('Failed to copy file: ' + fPath);" + LineEnding + LineEnding;
  Result += "    DeleteFile(f);" + LineEnding;
  Result += "    if (FindFiles(ExtractFilePath(f), True) = []) and (FindDirectories(ExtractFilePath(f), True) = []) then" + LineEnding;
  Result += "      DeleteDirectory(ExtractFilePath(f), False);" + LineEnding;
  Result += "  end;" + LineEnding + LineEnding;
  Result += "  RMDir(origin + pkg, True);" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "var" + LineEnding;
  Result += "  pkg: String;" + LineEnding + LineEnding;
  Result += "procedure Free();" + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  CloseFile(CreateFile({$MACRO CURRENT_DIRECTORY} + 'mover-' + LowerCase(pkg) + '.done'));" + LineEnding;
  Result += "end;" + LineEnding + LineEnding;
  Result += "begin" + LineEnding;
  Result += "  pkg := GetProcessParameter('pkg');" + LineEnding + LineEnding;
  Result += "  if FileExists({$MACRO CURRENT_DIRECTORY} + 'mover-' + LowerCase(pkg) + '.done') then" + LineEnding;
  Result += "    DeleteFile({$MACRO CURRENT_DIRECTORY} + 'mover-' + LowerCase(pkg) + '.done');" + LineEnding + LineEnding;
  Result += "  AddOnTerminate(@Free);" + LineEnding + LineEnding;
  Result += "  case LowerCase(pkg) of" + LineEnding;
  Result += "    'srl-t', 'srlt', 'srl': UnlockPlugins();" + LineEnding;
  Result += "  end;" + LineEnding + LineEnding;
  Result += "  WriteLn('[AsyncMover]: Moving ', pkg, ' files, this will take a while.');" + LineEnding;
  Result += "  MoveFiles(GetProcessParameter('origin'), pkg);" + LineEnding;
  Result += "end;" + LineEnding;
end;

procedure TWaspAsync.Setup();
begin
  Self.Path := LAUNCHER_DATA + 'async' + DirectorySeparator;

  if not ForceDirectories(LAUNCHER_DATA) then
    TerminateScript('WaspAsync failed to create directory: ' + LAUNCHER_DATA);

  if DirectoryExists(Self.Path) and not RMDir(Self.Path, True) then
    TerminateScript('WaspAsync failed to delete old files. Please manually delete:' + Self.Path);

  if DirectoryExists(LAUNCHER_DATA + 'downloads') and not RMDir(LAUNCHER_DATA + 'downloads') then
    TerminateScript('WaspAsync failed to delete old files. Please manually delete: ' + LAUNCHER_DATA + 'downloads' + DirectorySeparator);

  if not ForceDirectories(Self.Path) then
    TerminateScript('WaspAsync can''t create async directory.');

  Self.Write('downloader.simba', Self.GetDownloaderContent());
  Self.Write('unzipper.simba', Self.GetUnzipperContent());
  Self.Write('mover.simba', Self.GetMoverContent());
end;

var
  WaspAsync: TWaspAsync;

{$IFNDEF WS_CONFIG_INCLUDED}

{$DEFINE WS_CONFIG_INCLUDED}

function TJSONObject.getBoolean(key: String; acceptNull: Boolean): Boolean; constref; overload;
begin
  if not acceptNull then
    Exit(Self.getBoolean(key));

  Result := (Self <> nil) and Self.has(key) and not Self.isNull(key) and Self.getBoolean(key);
end;

function TJSONObject.put(key: string; Value: Boolean): TJSONObject; constref; override;
begin
  Self.Remove(key);
  Result := inherited(key, value);
end;

function TJSONObject.put(key: string; Value: Double): TJSONObject; constref; override;
begin
  Self.Remove(key);
  Result := inherited(key, value);
end;

function TJSONObject.put(key: string; Value: Integer): TJSONObject; constref; override;
begin
  Self.Remove(key);
  Result := inherited(key, value);
end;

function TJSONObject.put(key: string; Value: String): TJSONObject; constref; override;
begin
  Self.Remove(key);
  Result := inherited(key, value);
end;

function TJSONObject.put(key: string; Value: Pointer): TJSONObject; constref; override;
begin
  Self.Remove(key);
  Result := inherited(key, value);
end;

function TJSONObject.toString(): String; constref; override;
begin
  Result := inherited;
  Result := Result.ReplaceAll(
              [
                ['\u003A', ':'], ['\u0020', ' '],
                ['},{', '},' + LineEnding + '  {'],
                ['[{', '[' + LineEnding + '  {'],
                ['}]', '}' + LineEnding + ']']
              ]);
end;

function TJSONObject.toString(indentFactor: Integer): String; constref; override;
begin
  Result := inherited(indentFactor);
  Result := Result.ReplaceAll(
              [
                ['\u003A', ':'], ['\u0020', ' '],
                ['},{', '},' + LineEnding + '  {'],
                ['[{', '[' + LineEnding + '  {'],
                ['}]', '}' + LineEnding + ']']
              ]);
end;

function TJSONArray.toString(): String; constref; override;
begin
  Result := inherited;
  Result := Result.ReplaceAll(
              [
                ['\u003A', ':'], ['\u0020', ' '],
                ['},{', '},' + LineEnding + '  {'],
                ['[{', '[' + LineEnding + '  {'],
                ['}]', '}' + LineEnding + ']']
              ]);
end;

function TJSONArray.toString(indentFactor: Integer): String; constref; override;
begin
  Result := inherited(indentFactor);
  Result := Result.ReplaceAll(
              [
                ['\u003A', ':'], ['\u0020', ' '],
                ['},{', '},' + LineEnding + '  {'],
                ['[{', '[' + LineEnding + '  {'],
                ['}]', '}' + LineEnding + ']']
              ]);
end;

type

  TConfigJSON = record
    Path: String;
    JSON: TJSONObject;
    IsSetup, OnTerminate: Boolean;
  end;

function TConfigJSON.GetConfig(): TJSONObject;
var
  str: String;
begin
  if FileExists(Self.Path) then
  begin
    str := ReadFileContents(Self.Path);
    if str <> '' then
    begin
      try
        Result.Init(str);
      except
        Result := nil;
        Result.Init();
      end;
      Exit;
    end;
  end;

  Result.Init();
end;

procedure TConfigJSON.Free();
begin
  if not Self.IsSetup then Exit;

  Self.JSON.Free();
  Self.JSON := nil;

  Self.IsSetup := False;
end;

procedure TConfigJSON.Setup(jsonFile: String = ScriptName);
begin
  if jsonFile.Contains(DirectorySeparator) then
  begin
    Self.Path := ExtractFilePath(jsonFile);
    jsonFile := ExtractFileName(jsonFile);
  end
  else
    Self.Path := AppPath + 'Configs' + DirectorySeparator;

  if not ForceDirectories(Self.Path) then
    TerminateScript('Can''t create configs directory.');

  if not jsonFile.EndsWith('.json') then
    jsonFile += '.json';
  Self.Path += jsonFile;

  Self.JSON := Self.GetConfig();
  Self.IsSetup := True;

  if not Self.OnTerminate then
  begin
    AddOnTerminate(@Self.Free);
    Self.OnTerminate := True;
  end;
end;

procedure TConfigJSON.SaveConfig();
begin
  if Self.JSON = nil then
    TerminateScript('You need to use TConfigJSON.Setup() before trying to save it into a config file.');

  if not WriteFileContents(Self.Path, json.ToString(1), False) then
    TerminateScript('Failed to save config.');
end;

procedure TConfigJSON.Put(key, value: String; save: Boolean = True);
begin
  if Self.JSON = nil then
    Exit;
  Self.JSON.Put(key, value);
  if save then
    Self.SaveConfig();
end;

function TConfigJSON.GetString(key: String): String;
begin
  if Self.JSON = nil then
    Exit;
  if Self.JSON.has(key) and not Self.JSON.isNull(key) then
    Result := Self.JSON.getString(key);
end;

procedure TConfigJSON.Remove(key: String);
begin
  if Self.JSON = nil then
    TerminateScript('You need to use TConfigJSON.Setup() before trying to delete a key on it.');
  Self.JSON.remove(key);
  Self.SaveConfig();
end;

{$IFNDEF WS_HTTP_INCLUDED}

{$DEFINE WS_HTTP_INCLUDED}

var
  LauncherConfig: TConfigJSON;

type
  THTTPClient = record
    Name: String;
    Client: Int32;
    Server: String;
  end;

function THTTPClient.GetHTTPCode(): Int32;
begin
  Result := GetHTTPResponseCode(Self.Client);
end;

procedure THTTPClient.Free();
begin
  FreeHTTPClient(Self.Client);
end;

function THTTPClient.GET(route: String; verbose: Boolean = True): String;
var
  time: UInt64;
begin
  time := GetTickCount();
  Result := GetHTTPPage(Self.Client, Self.Server + route);
  time := GetTickCount() - time;
  Result := StringReplace(Result, '\u0020', ' ', [rfReplaceAll]);
  if verbose then
    {$IFNDEF DEVELOPER_MODE}
    DebugLn(Self.Name, 'HTTPCode: ' + ToStr(Self.GetHTTPCode()) + ' - ' + Result + ' - Response took: ' + ToStr(time) + 'ms.');
    {$ELSE}
    DebugLn(Self.Name, 'HTTPCode: ' + ToStr(Self.GetHTTPCode()) + ' - Response took: ' + ToStr(time) + 'ms.');
    {$ENDIF}
end;

function THTTPClient.POST(route: String; verbose: Boolean = True): String;
var
  time: UInt64;
begin
  time := GetTickCount();
  ClearPostData(Self.Client);
  Result := PostHTTPPageEx(Self.Client, Self.Server + route);
  time := GetTickCount() - time;
  Result := StringReplace(Result, '\u0020', ' ', [rfReplaceAll]);
  if verbose then
    {$IFNDEF DEVELOPER_MODE}
    DebugLn(Self.Name, 'HTTPCode: ' + ToStr(Self.GetHTTPCode()) + ' - ' + Result + ' - Response took: ' + ToStr(time) + 'ms.');
    {$ELSE}
    DebugLn(Self.Name, 'HTTPCode: ' + ToStr(Self.GetHTTPCode()) + ' - Response took: ' + ToStr(time) + 'ms.');
    {$ENDIF}
end;

function THTTPClient.POST(route: String; payload: String; verbose: Boolean = True): String; overload;
var
  time: UInt64;
begin
  time := GetTickCount();
  Result := PostHTTPPage(Self.Client, Self.Server + route, payload);
  time := GetTickCount() - time;
  Result := StringReplace(Result, '\u0020', ' ', [rfReplaceAll]);
  if verbose then
    {$IFNDEF DEVELOPER_MODE}
    DebugLn(Self.Name, 'HTTPCode: ' + ToStr(Self.GetHTTPCode()) + ' - ' + Result + ' - Response took: ' + ToStr(time) + 'ms.');
    {$ELSE}
    DebugLn(Self.Name, 'HTTPCode: ' + ToStr(Self.GetHTTPCode()) + ' - Response took: ' + ToStr(time) + 'ms.');
    {$ENDIF}
end;

function THTTPClient.POST(route: String; payload: TJSONObject; verbose: Boolean = True): String; overload;
begin
  Result := Self.POST(route, payload.toString(), verbose);
end;

type
  TGitHubClient = record(THTTPClient)
    DownloadPath: String;
    Packages: record
      Current: record
        SRLT: String;
        WaspLib: String;
      end;
      Latest: record
        SRLT: String;
        WaspLib: String;
      end;
      Release: record
        SRLT: String;
        WaspLib: String;
      end;
    end;
  end;

procedure TGitHubClient.RefreshClient(isSetup: Boolean = True);
begin
  if isSetup then Self.Free();
  Self.Client := InitializeHTTPClient(True);

  SetHTTPContentType(Self.Client, 'application/json');
  SetHTTPHeader(Self.Client, 'Accept', 'application/vnd.github+json');
  SetHTTPHeader(Self.Client, 'User-Agent', 'B.A.S.H-Launcher');
end;

function TGitHubClient.GetLatestPackage(owner, repo: String): TJSONObject;
const
  ROUTE: String = 'repos/';
var
  response: String;
begin
  Result := nil;
  try
    response := Self.GET(ROUTE + owner + '/' + repo + '/releases/latest', {$IFDEF DEVELOPER_MODE}True{$ELSE}False{$ENDIF});

    if Self.GetHTTPCode() = 200 then
      Result.Init(response);
  except
    Result := nil;
  end;
end;

function TGitHubClient.GetCurrentPackageVersion(pkg: String): String;
var
  path: String;
begin
  path := INCLUDEPATH + pkg + DIRECTORYSEPARATOR + 'CHANGELOG.md';

  Result := ReadFileContents(path);
  Result := Result.After('# [').Before('](https');
end;

procedure TGitHubClient.LoadPackageVersions();
var
  json: TJSONObject;
begin
  json := Self.GetLatestPackage(GITHUB_SRLT_OWNER, GITHUB_SRLT_REPO);
  if json <> nil then
  begin
    Self.Packages.Latest.SRLT := json.getString('name').After('v');
    Self.Packages.Release.SRLT := json.getString('zipball_url');
    json.Free();
  end
  else
    Self.Packages.Latest.SRLT := 'failed';

  json := Self.GetLatestPackage(GITHUB_WASPLIB_OWNER, GITHUB_WASPLIB_REPO);
  if json <> nil then
  begin
    Self.Packages.Latest.WaspLib := json.getString('name').After('v');
    Self.Packages.Release.WaspLib := json.getString('zipball_url');
    json.Free();
  end
  else
    Self.Packages.Latest.WaspLib := 'failed';
end;

procedure TGitHubClient.Setup();
begin
  Self.Name := 'GitHub Client';
  Self.Server := 'https://api.github.com/';
  Self.DownloadPath := LAUNCHER_DATA + 'downloads' + DirectorySeparator;

  if not ForceDirectories(Self.DownloadPath) then
    TerminateScript('GitHubClient can''t create downloads directory.');

  Self.RefreshClient(False);
  AddOnTerminate(@Self.Free);

  Self.Packages.Current.SRLT := Self.GetCurrentPackageVersion(SRLT_INSTALL_DIR);
  Self.Packages.Current.WaspLib := Self.GetCurrentPackageVersion(WASPLIB_INSTALL_DIR);
  Self.LoadPackageVersions();
end;

procedure TGitHubClient.Download(pkg: String);
var
  url: String;
  params: TStringArray;
begin
  case LowerCase(pkg) of
    'srlt', 'srl-t': url := Self.Packages.Release.SRLT;
    'wl', 'wasplib': url := Self.Packages.Release.WaspLib;
    else
      TerminateScript('Unrecognized package to download: ' + pkg);
  end;

  params := ['url=' + url,'destination="'+ Self.DownloadPath + pkg + '.zip"', 'pkg=' + pkg];
  WaspAsync.Run('downloader', params);
end;

function TGitHubClient.HasDownloadURL(pkg: String): Boolean;
begin
  case LowerCase(pkg) of
    'srlt', 'srl-t': Result := Self.Packages.Release.SRLT <> '';
    'wl', 'wasplib': Result := Self.Packages.Release.WaspLib <> '';
    else Result := False;
  end;
end;

var
  GitHubClient: TGitHubClient;

type
  EScriptStatus = (OFFICIAL, COMMUNITY);
  EScriptType = (FREE, PREMIUM, PREMIUM_NO_SUB, TESTING, TESTING_NO_SUB, FULL, FULL_NO_SUB);
  EScriptSource = (BASH, LOCAL);

  TScriptData = record
    ID: String;
    Name: String;
    Description: String;
    Content: String;
    URL: String;
    LocalPath: String;
    Status: EScriptStatus;
    Typ: EScriptType;
    Source: EScriptSource;
    Revision: Int32;
    Activities: TStringArray;
  end;

  TScriptDataArray = array of TScriptData;

function TScriptDataArray.Find(const id: String): Int32; constref;
begin
  for Result := 0 to High(Self) do
    if Self[Result].ID = id then
      Exit;
  Result := -1;
end;

function ScriptDataSort(constref left, right: TScriptData): Int32;
begin
  if LowerCase(left.Name) > LowerCase(right.Name) then
    Exit(1);
  if LowerCase(left.Name) < LowerCase(right.Name) then
    Exit(-1);
end;

function TScriptDataArray.Sorted(): TScriptDataArray;
begin
  Result := System.Sorted(Self, @ScriptDataSort);
end;

function NormalizeActivityId(const value: String): String;
var
  known: TStringArray;
  id: String;
begin
  id := LowerCase(Trim(value));
  // Combat skills
  if (id = 'attack') or (id = 'defence') or (id = 'defense') or (id = 'hitpoint') or
     (id = 'hitpoints') or (id = 'hp') or (id = 'strength') then
    id := 'combat'
  else if id = 'minigames' then
    id := 'minigame'
  else if id = 'runecrafting' then
    id := 'runecraft'
  else if (id = 'boss') or (id = 'bosses') then
    id := 'bossing';

  known := String(BASH_ACTIVITY_IDS).Split(',');
  if known.Contains(id) then
    Result := id
  else
    Result := '';
end;

function ParseActivitiesText(const raw: String): TStringArray;
var
  parts: TStringArray;
  i: Int32;
  id: String;
begin
  Result := [];
  if Trim(raw) = '' then
    Exit;
  parts := raw.Replace(';', ',').Replace('|', ',').Replace('/', ',').Split(',');
  for i := 0 to High(parts) do
  begin
    id := NormalizeActivityId(parts[i]);
    if (id <> '') and (not Result.Contains(id)) then
      Result += id;
  end;
end;

function ParseActivitiesJSON(item: TJSONObject): TStringArray;
var
  arr: TJSONArray;
  raw: String;
begin
  Result := [];
  if item = nil then
    Exit;

  arr := item.optJSONArray('activities');
  if arr = nil then
    arr := item.optJSONArray('tags');
  if arr <> nil then
  begin
    raw := arr.toString();
    raw := raw.Replace('[', '').Replace(']', '').Replace('"', '').Replace('''', '');
    Result := ParseActivitiesText(raw);
  end;

  if Length(Result) = 0 then
  begin
    raw := item.optString('activities', '');
    if raw = '' then
      raw := item.optString('tags', '');
    Result := ParseActivitiesText(raw);
  end;
end;

function InferScriptActivities(const name, path: String; existing: TStringArray): TStringArray;
var
  hay, folder: String;
  parts: TStringArray;
begin
  Result := existing;
  if Length(Result) > 0 then
    Exit;

  hay := LowerCase(name + ' ' + path);
  folder := '';
  parts := path.Replace('\', '/').Split('/');
  if Length(parts) > 1 then
    folder := LowerCase(parts[0]);

  // Gathering
  if (folder = 'farming') or hay.Contains('farm') then
    Result += 'farming';
  if (folder = 'fishing') or hay.Contains('fish') then
    Result += 'fishing';
  if (folder = 'hunter') or hay.Contains('hunter') or hay.Contains('chinchompa') or hay.Contains('trapping') then
    Result += 'hunter';
  if (folder = 'mining') or hay.Contains('mining') or hay.Contains('miner') or hay.Contains('barronite') or hay.Contains('calcified') then
    Result += 'mining';
  if (folder = 'woodcutting') or hay.Contains('woodcut') or hay.Contains('chopper') or hay.Contains('ironwood') or hay.Contains('roots') then
    Result += 'woodcutting';

  // Production
  if (folder = 'cooking') or hay.Contains('cook') then
    Result += 'cooking';
  if (folder = 'crafting') or hay.Contains('craft') then
    Result += 'crafting';
  if (folder = 'fletching') or hay.Contains('fletch') then
    Result += 'fletching';
  if (folder = 'herblore') or hay.Contains('herb') then
    Result += 'herblore';
  if (folder = 'runecraft') or hay.Contains('runecraft') or hay.Contains('essence') then
    Result += 'runecraft';
  if (folder = 'smithing') or hay.Contains('smith') or hay.Contains('smelt') or hay.Contains('cannonball') then
    Result += 'smithing';

  // Utility skills
  if (folder = 'agility') or hay.Contains('agility') or hay.Contains('roofhop') then
    Result += 'agility';
  if (folder = 'construction') or hay.Contains('construction') or hay.Contains('totem') then
    Result += 'construction';
  if (folder = 'firemaking') or hay.Contains('firemak') or hay.Contains('wintertodt') then
    Result += 'firemaking';
  if (folder = 'sailing') or hay.Contains('sail') or hay.Contains('shipwreck') or hay.Contains('salvag') then
    Result += 'sailing';
  if (folder = 'slayer') or hay.Contains('slayer') then
    Result += 'slayer';
  if (folder = 'thieving') or hay.Contains('thiev') or hay.Contains('blackjack') then
    Result += 'thieving';

  // Combat skills
  if (folder = 'magic') or hay.Contains('magic') or hay.Contains('lunar') or hay.Contains('superheat') then
    Result += 'magic';
  if (folder = 'prayer') or hay.Contains('prayer') or hay.Contains('bones') then
    Result += 'prayer';
  if (folder = 'ranged') or hay.Contains('ranged') or hay.Contains('range ') then
    Result += 'ranged';
  if (folder = 'combat') or hay.Contains('combat') or hay.Contains('attack') or hay.Contains('strength') or
     hay.Contains('defence') or hay.Contains('hitpoint') then
    Result += 'combat';

  // Bossing / minigames
  if (folder = 'bossing') or (folder = 'boss') or hay.Contains('boss') or hay.Contains('vardorvis') or
     hay.Contains('tormented') or hay.Contains('demon') then
    Result += 'bossing';
  if (folder = 'minigame') or (folder = 'minigames') or hay.Contains('minigame') or hay.Contains('squirkin') or
     hay.Contains('trouble brewing') or hay.Contains('gemstone crab') or hay.Contains('crab slayer') then
    Result += 'minigame';

  // Generic
  if (Length(Result) = 0) and (hay.Contains('crab') or hay.Contains('kill') or hay.Contains('fight')) then
    Result += 'combat';
end;

function ScriptMatchesActivity(const script: TScriptData; const activity: String): Boolean;
var
  id: String;
begin
  id := NormalizeActivityId(activity);
  if (id = '') or (id = 'all') then
    Exit(True);
  Result := script.Activities.Contains(id);
end;

function GetCategoryActivityIds(const category: String): TStringArray;
var
  c: String;
begin
  c := LowerCase(Trim(category));
  if c = 'combat' then
    Result := ['combat', 'magic', 'prayer', 'ranged']
  else if c = 'gathering' then
    Result := ['farming', 'fishing', 'hunter', 'mining', 'woodcutting']
  else if c = 'production' then
    Result := ['cooking', 'crafting', 'fletching', 'herblore', 'runecraft', 'smithing']
  else if c = 'utility' then
    Result := ['agility', 'construction', 'firemaking', 'sailing', 'slayer', 'thieving']
  else if c = 'other' then
    Result := ['minigame', 'bossing']
  else
    Result := [];
end;

function ActivityLabelForId(const activityId: String): String;
var
  ids, labels: TStringArray;
  i: Int32;
begin
  ids := String(BASH_ACTIVITY_IDS).Split(',');
  labels := String(BASH_ACTIVITY_LABELS).Split(',');
  for i := 0 to High(ids) do
    if ids[i] = activityId then
    begin
      if i <= High(labels) then
        Exit(labels[i]);
      Exit(activityId);
    end;
  Result := activityId;
end;

function ScriptMatchesFilter(const script: TScriptData; const filter, category: String): Boolean;
var
  f, c: String;
  acts: TStringArray;
  i: Int32;
begin
  f := LowerCase(Trim(filter));
  c := LowerCase(Trim(category));
  if f = '' then
    f := 'all';
  if c = '' then
    c := 'all';

  if f <> 'all' then
    Exit(ScriptMatchesActivity(script, f));

  if c = 'all' then
    Exit(True);

  acts := GetCategoryActivityIds(c);
  for i := 0 to High(acts) do
    if script.Activities.Contains(acts[i]) then
      Exit(True);
  Result := False;
end;

type
  TBashLicenseClient = record
    Server: String;
    Key: String;
    Scripts: TScriptDataArray;
    CatalogScripts: TScriptDataArray;
    Loaded: Boolean;
    CatalogLoaded: Boolean;
    Valid: Boolean;
    LastError: String;
    ExpiresAt: String;
  end;

function TBashLicenseClient.GetKey(): String;
begin
  Result := Self.Key;
  if Result = '' then
    Result := LauncherConfig.GetString('license_key');
end;

procedure TBashLicenseClient.SetKey(const value: String; save: Boolean = True);
begin
  Self.Key := System.Trim(value);
  Self.Loaded := False;
  Self.Valid := False;
  Self.Scripts := [];
  Self.LastError := '';
  Self.ExpiresAt := '';
  if save then
  begin
    if Self.Key = '' then
      LauncherConfig.Remove('license_key')
    else
      LauncherConfig.Put('license_key', Self.Key);
  end;
end;

procedure TBashLicenseClient.ClearKey();
begin
  Self.SetKey('', True);
end;

function TBashLicenseClient.HasKey(): Boolean;
begin
  Result := Self.GetKey() <> '';
end;

function TBashLicenseClient.GetInstallId(): String;
var
  i: Int32;
  hex: String;
const
  HEXCHARS = '0123456789abcdef';
begin
  Result := LauncherConfig.GetString('install_id');
  if Result <> '' then
    Exit;

  hex := '';
  for i := 1 to 32 do
    hex += HEXCHARS[1 + System.Random(0, 15)];
  Result :=
    Copy(hex, 1, 8) + '-' +
    Copy(hex, 9, 4) + '-' +
    Copy(hex, 13, 4) + '-' +
    Copy(hex, 17, 4) + '-' +
    Copy(hex, 21, 12);
  LauncherConfig.Put('install_id', Result);
end;

function TBashLicenseClient.ParseCatalogScripts(scriptsArr: TJSONArray; locked: Boolean): TScriptDataArray;
var
  i: Int32;
  item: TJSONObject;
  script: TScriptData;
  tier: String;
begin
  Result := [];
  if scriptsArr = nil then
    Exit;

  for i := 0 to scriptsArr.High() do
  begin
    item := scriptsArr.optJSONObject(i);
    if item = nil then
      Continue;

    script.ID := item.optString('id', '');
    script.Name := item.optString('name', '');
    script.Description := item.optString('description', '');
    script.URL := item.optString('path', item.optString('url', ''));
    script.Revision := item.optInt('revision', 0);
    script.Status := EScriptStatus.OFFICIAL;
    script.Source := EScriptSource.BASH;
    script.Content := '';
    script.LocalPath := '';
    script.Activities := InferScriptActivities(script.Name, script.URL, ParseActivitiesJSON(item));

    tier := LowerCase(item.optString('type', 'premium'));
    if tier = 'free' then
      script.Typ := EScriptType.FREE
    else if tier = 'testing' then
    begin
      if locked then
        script.Typ := EScriptType.TESTING_NO_SUB
      else
        script.Typ := EScriptType.TESTING;
    end
    else if tier = 'full' then
    begin
      if locked then
        script.Typ := EScriptType.FULL_NO_SUB
      else
        script.Typ := EScriptType.FULL;
    end
    else
    begin
      if locked then
        script.Typ := EScriptType.PREMIUM_NO_SUB
      else
        script.Typ := EScriptType.PREMIUM;
    end;

    if script.ID = '' then
      Continue;
    if script.URL = '' then
      script.URL := script.Name + '.simba';
    if script.Name = '' then
      script.Name := ExtractFileName(script.URL).Before('.simba');
    if script.Revision = 0 then
      script.Revision := 1;

    Result += script;
  end;

  Result := Result.Sorted();
end;

function TBashLicenseClient.ParseEntitlementScripts(scriptsArr: TJSONArray): TScriptDataArray;
begin
  Result := Self.ParseCatalogScripts(scriptsArr, False);
end;

function TBashLicenseClient.FetchPublicCatalog(force: Boolean = False): TScriptDataArray;
var
  http, code: Int32;
  url, response: String;
  json: TJSONObject;
  scriptsArr: TJSONArray;
begin
  if Self.CatalogLoaded and (not force) then
    Exit(Self.CatalogScripts);

  Result := [];
  Self.CatalogScripts := [];
  Self.CatalogLoaded := True;

  url := Self.Server + '/v1/catalog';
  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    SetHTTPHeader(http, 'Accept', 'application/json');
    try
      SetSocketTimeout(http, 20000);
    except
    end;

    response := GetHTTPPage(http, url);
    code := GetHTTPResponseCode(http);
  finally
    FreeHTTPClient(http);
  end;

  if code <> 200 then
  begin
    WriteLn('[B.A.S.H] Premium catalog /v1/catalog failed (HTTP ', code, ').');
    Exit;
  end;

  try
    json.Init(response);
  except
    Exit;
  end;

  try
    scriptsArr := json.optJSONArray('scripts');
    Result := Self.ParseCatalogScripts(scriptsArr, True);
    Self.CatalogScripts := Result;
  finally
    json.Free();
  end;
end;

function TBashLicenseClient.FetchEntitlements(force: Boolean = False): TScriptDataArray;
var
  http, code: Int32;
  key, url, response: String;
  json: TJSONObject;
  scriptsArr: TJSONArray;
begin
  if Self.Loaded and (not force) then
    Exit(Self.Scripts);

  Result := [];
  Self.Scripts := [];
  Self.Valid := False;
  Self.LastError := '';
  Self.ExpiresAt := '';
  Self.Loaded := True;

  key := Self.GetKey();
  if key = '' then
  begin
    Self.LastError := 'no_license_key';
    Exit;
  end;

  url := Self.Server + '/v1/me';
  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    SetHTTPHeader(http, BASH_LICENSE_HEADER, key);
    SetHTTPHeader(http, BASH_INSTALL_HEADER, Self.GetInstallId());
    SetHTTPHeader(http, 'Accept', 'application/json');
    try
      SetSocketTimeout(http, 20000);
    except
    end;

    response := GetHTTPPage(http, url);
    code := GetHTTPResponseCode(http);
  finally
    FreeHTTPClient(http);
  end;

  if (code = 401) or (code = 403) then
  begin
    if response.Contains('license_expired') then
      Self.LastError := 'license_expired'
    else
      Self.LastError := 'license_revoked_or_invalid';
    WriteLn('[B.A.S.H] License key rejected (HTTP ', code, ', ', Self.LastError, '). Premium updates unavailable; local copies kept.');
    Exit;
  end;

  if code <> 200 then
  begin
    Self.LastError := 'http_' + ToStr(code);
    WriteLn('[B.A.S.H] Premium API /v1/me failed (HTTP ', code, ').');
    Exit;
  end;

  try
    json.Init(response);
  except
    Self.LastError := 'bad_json';
    Exit;
  end;

  try
    if not json.getBoolean('valid', True) then
    begin
      Self.LastError := json.optString('error', 'invalid');
      Exit;
    end;

    Self.ExpiresAt := json.optString('expires_at', '');
    scriptsArr := json.optJSONArray('scripts');
    Result := Self.ParseEntitlementScripts(scriptsArr);
    Self.Scripts := Result;
    Self.Valid := True;
  finally
    json.Free();
  end;
end;

function FormatLicenseExpiryDate(const iso: String): String;
begin
  Result := iso;
  if Length(iso) < 10 then
    Exit;
  Result := Copy(iso, 9, 2) + '-' + Copy(iso, 6, 2) + '-' + Copy(iso, 1, 4);
end;

function TBashLicenseClient.DownloadPremium(script: TScriptData): Boolean;
var
  http, code: Int32;
  key, url, dest, scriptsPath, tempDest, errBody: String;
begin
  Result := False;
  key := Self.GetKey();
  if key = '' then
  begin
    MessageDlg('B.A.S.H', 'Enter a license key to install or update premium scripts.', TMsgDlgType.mtWarning, []);
    Exit;
  end;

  scriptsPath := ScriptPath + 'bigaussie' + DirectorySeparator;
  if not ForceDirectories(scriptsPath) then
  begin
    MessageDlg('B.A.S.H', 'Failed to create scripts folder: ' + scriptsPath, TMsgDlgType.mtError, []);
    Exit;
  end;

  dest := scriptsPath + ExtractFileName(script.URL);
  tempDest := dest + '.download';
  url := Self.Server + '/v1/scripts/' + script.ID + '/download';

  WriteLn('[B.A.S.H] Downloading premium script: ', script.Name);
  WriteLn('[B.A.S.H] URL: ', url);
  WriteLn('[B.A.S.H] Dest: ', dest);

  if FileExists(tempDest) then
    DeleteFile(tempDest);

  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    SetHTTPHeader(http, BASH_LICENSE_HEADER, key);
    SetHTTPHeader(http, BASH_INSTALL_HEADER, Self.GetInstallId());
    try
      SetSocketTimeout(http, 60000);
    except
    end;

    code := GetHTTPPageEx(http, url, tempDest);
    WriteLn('[B.A.S.H] Premium download HTTP code: ', code);

    if (code = 401) or (code = 403) then
    begin
      errBody := '';
      if FileExists(tempDest) then
      begin
        try
          errBody := ReadFileContents(tempDest);
        except
        end;
        DeleteFile(tempDest);
      end;
      Self.Loaded := False;
      Self.Valid := False;
      Self.Scripts := [];
      if errBody.Contains('license_expired') then
        Self.LastError := 'license_expired'
      else
        Self.LastError := 'access_revoked';

      if Self.LastError = 'license_expired' then
        MessageDlg(
          'B.A.S.H',
          'License expired for "' + script.Name + '".' + LineEnding +
          'Your local copy (if any) was kept. Renew access to download updates.',
          TMsgDlgType.mtWarning,
          []
        )
      else
        MessageDlg(
          'B.A.S.H',
          'Access revoked or invalid license key for "' + script.Name + '".' + LineEnding +
          'Your local copy (if any) was kept. New updates are unavailable until access is restored.',
          TMsgDlgType.mtWarning,
          []
        );
      Exit;
    end;

    if code <> 200 then
    begin
      if FileExists(tempDest) then
        DeleteFile(tempDest);
      MessageDlg('B.A.S.H', 'Failed to download premium script "' + script.Name + '" (HTTP ' + ToStr(code) + ').', TMsgDlgType.mtError, []);
      Exit;
    end;

    if not FileExists(tempDest) then
    begin
      MessageDlg('B.A.S.H', 'Download reported OK but file was not written: ' + tempDest, TMsgDlgType.mtError, []);
      Exit;
    end;

    if FileExists(dest) and (not DeleteFile(dest)) then
    begin
      DeleteFile(tempDest);
      MessageDlg('B.A.S.H', 'Could not replace existing script file: ' + dest, TMsgDlgType.mtError, []);
      Exit;
    end;

    if not RenameFile(tempDest, dest) then
    begin
      try
        WriteFileContents(dest, ReadFileContents(tempDest), False);
        DeleteFile(tempDest);
      except
        if FileExists(tempDest) then
          DeleteFile(tempDest);
        MessageDlg('B.A.S.H', 'Download OK but failed to finalize: ' + dest, TMsgDlgType.mtError, []);
        Exit;
      end;
    end;

    WriteLn('[B.A.S.H] Premium script saved: ', dest);
    Result := True;
  except
    if FileExists(tempDest) then
      DeleteFile(tempDest);
    WriteLn('[B.A.S.H] Premium download error: ', GetExceptionMessage());
    MessageDlg('B.A.S.H', 'Download error for "' + script.Name + '": ' + GetExceptionMessage(), TMsgDlgType.mtError, []);
  finally
    FreeHTTPClient(http);
  end;
end;

function TBashLicenseClient.DownloadFree(script: TScriptData): Boolean;
var
  http, code: Int32;
  url, dest, scriptsPath, tempDest: String;
begin
  Result := False;
  if script.ID = '' then
    Exit;

  scriptsPath := ScriptPath + 'bigaussie' + DirectorySeparator;
  if not ForceDirectories(scriptsPath) then
  begin
    MessageDlg('B.A.S.H', 'Failed to create scripts folder: ' + scriptsPath, TMsgDlgType.mtError, []);
    Exit;
  end;

  dest := scriptsPath + ExtractFileName(script.URL).Replace('%20', ' ');
  if dest.EndsWith(DirectorySeparator) or (ExtractFileName(script.URL) = '') then
    dest := scriptsPath + script.Name + '.simba';
  tempDest := dest + '.download';
  url := Self.Server + '/v1/scripts/' + script.ID + '/download';

  WriteLn('[B.A.S.H] Downloading free script: ', script.Name);

  if FileExists(tempDest) then
    DeleteFile(tempDest);

  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    SetHTTPHeader(http, BASH_INSTALL_HEADER, Self.GetInstallId());
    try
      SetSocketTimeout(http, 60000);
    except
    end;

    code := GetHTTPPageEx(http, url, tempDest);
    if code <> 200 then
    begin
      if FileExists(tempDest) then
        DeleteFile(tempDest);
      Exit;
    end;

    if not FileExists(tempDest) then
      Exit;

    if FileExists(dest) and (not DeleteFile(dest)) then
    begin
      DeleteFile(tempDest);
      MessageDlg('B.A.S.H', 'Could not replace existing script file: ' + dest, TMsgDlgType.mtError, []);
      Exit;
    end;

    if not RenameFile(tempDest, dest) then
    begin
      try
        WriteFileContents(dest, ReadFileContents(tempDest), False);
        DeleteFile(tempDest);
      except
        if FileExists(tempDest) then
          DeleteFile(tempDest);
        Exit;
      end;
    end;

    WriteLn('[B.A.S.H] Free script saved: ', dest);
    Result := True;
  except
    if FileExists(tempDest) then
      DeleteFile(tempDest);
  finally
    FreeHTTPClient(http);
  end;
end;

procedure TBashLicenseClient.Setup();
begin
  Self.Server := BASH_PREMIUM_API;
  Self.Key := LauncherConfig.GetString('license_key');
  Self.GetInstallId();
  Self.Scripts := [];
  Self.CatalogScripts := [];
  Self.Loaded := False;
  Self.CatalogLoaded := False;
  Self.Valid := False;
  Self.LastError := '';
  Self.ExpiresAt := '';
end;

var
  BashLicenseClient: TBashLicenseClient;

type
  TBashScriptClient = record(THTTPClient)
    Repo: String;
    Branch: String;
    ScriptsPath: String;
    DownloadPath: String;
    Scripts: TScriptDataArray;
    LocalScripts: TScriptDataArray;
    Loaded: Boolean;
    LocalLoaded: Boolean;
    ActiveSource: EScriptSource;
  end;

procedure TBashScriptClient.RefreshClient(isSetup: Boolean = True);
begin
  if isSetup then Self.Free();
  Self.Client := InitializeHTTPClient(True);

  SetHTTPContentType(Self.Client, 'application/json');
  SetHTTPHeader(Self.Client, 'Accept', 'application/vnd.github+json');
  SetHTTPHeader(Self.Client, 'User-Agent', 'B.A.S.H-Launcher');
end;

function EncodeGitHubPath(const path: String): String;
begin

  Result := path.Replace('\', '/').Replace(' ', '%20');
end;

function TBashScriptClient.FetchRawHeader(path: String): String;
var
  http: Int32;
  url: String;
begin
  url := 'https://raw.githubusercontent.com/' + Self.Repo + '/' + Self.Branch + '/' + EncodeGitHubPath(path);
  http := InitializeHTTPClient(True);
  try
    Result := GetHTTPPage(http, url);
    if GetHTTPResponseCode(http) <> 200 then
      Result := '';
    if Length(Result) > 8192 then
      SetLength(Result, 8192);
  finally
    FreeHTTPClient(http);
  end;
end;

function ExtractScriptDescription(const header: String): String;
var
  i, start, closeBrace: Int32;
begin
  i := 1;
  while i <= Length(header) do
  begin
    if header[i] <> '{' then
    begin
      Inc(i);
      Continue;
    end;

    if (i < Length(header)) and (header[i + 1] = '$') then
    begin
      closeBrace := i + 1;
      while (closeBrace <= Length(header)) and (header[closeBrace] <> '}') do
        Inc(closeBrace);
      i := closeBrace + 1;
      Continue;
    end;

    start := i + 1;
    closeBrace := start;
    while (closeBrace <= Length(header)) and (header[closeBrace] <> '}') do
      Inc(closeBrace);

    if closeBrace > Length(header) then
      Exit;

    Result := Copy(header, start, closeBrace - start).Trim();
    Exit;
  end;
end;

function ScriptDisplayNameFromPath(const path: String): String;
var
  fileName: String;
begin
  fileName := ExtractFileName(path).Replace('%20', ' ');
  if LowerCase(fileName).EndsWith('.simba') then
    Result := Copy(fileName, 1, Length(fileName) - Length('.simba'))
  else
    Result := fileName;
end;

function TBashScriptClient.ParseScriptHeader(const header, path: String): TScriptData;
var
  idStr, revStr, description, actsStr: String;
begin
  Result.URL := path;
  Result.LocalPath := '';
  Result.Name := ScriptDisplayNameFromPath(path);
  Result.Typ := EScriptType.FREE;
  Result.Status := EScriptStatus.OFFICIAL;
  Result.Source := EScriptSource.BASH;
  Result.Activities := [];

  if header.Contains('SCRIPT_ID') then
  begin
    idStr := header.After('SCRIPT_ID := ''').Before('''}');
    if idStr = '' then
      idStr := header.After('SCRIPT_ID := "').Before('"}');
    Result.ID := idStr;
  end;

  if Result.ID = '' then
    Result.ID := path;

  revStr := header.After('SCRIPT_REVISION := ''').Before('''}');
  if revStr = '' then
    revStr := header.After('SCRIPT_REVISION := "').Before('"}');
  Result.Revision := StrToIntDef(revStr, 0);

  if header.Contains('SCRIPT_ACTIVITIES') then
  begin
    actsStr := header.After('SCRIPT_ACTIVITIES := ''').Before('''}');
    if actsStr = '' then
      actsStr := header.After('SCRIPT_ACTIVITIES := "').Before('"}');
    Result.Activities := ParseActivitiesText(actsStr);
  end;

  description := ExtractScriptDescription(header);
  if description <> '' then
    Result.Description := description;

  Result.Activities := InferScriptActivities(Result.Name, path, Result.Activities);
end;

function TBashScriptClient.ScriptsFromCatalogArray(scriptsArr: TJSONArray): TScriptDataArray;
var
  i: Int32;
  item: TJSONObject;
  script: TScriptData;
begin
  Result := [];
  if scriptsArr = nil then
    Exit;

  for i := 0 to scriptsArr.High() do
  begin
    item := scriptsArr.optJSONObject(i);
    if item = nil then
      Continue;

    script.ID := item.optString('id', '');
    script.Description := item.optString('description', '');
    script.URL := item.optString('path', item.optString('url', ''));
    script.Revision := item.optInt('revision', 0);
    script.Status := EScriptStatus.OFFICIAL;
    script.Source := EScriptSource.BASH;
    script.Content := '';
    script.LocalPath := '';

    if script.URL <> '' then
      script.Name := ScriptDisplayNameFromPath(script.URL)
    else
      script.Name := item.optString('name', '');
    script.Activities := InferScriptActivities(script.Name, script.URL, ParseActivitiesJSON(item));

    case LowerCase(item.optString('type', 'free')) of
      'premium': script.Typ := EScriptType.PREMIUM;
      'premium_no_sub': script.Typ := EScriptType.PREMIUM_NO_SUB;
      'testing': script.Typ := EScriptType.TESTING;
      'testing_no_sub': script.Typ := EScriptType.TESTING_NO_SUB;
      'full': script.Typ := EScriptType.FULL;
      'full_no_sub': script.Typ := EScriptType.FULL_NO_SUB;
      else script.Typ := EScriptType.FREE;
    end;

    if script.URL = '' then
      Continue;
    if script.Name = '' then
      script.Name := ScriptDisplayNameFromPath(script.URL);
    if script.ID = '' then
      script.ID := script.URL;

    if script.Typ <> EScriptType.FREE then
      Continue;

    Result += script;
  end;

  Result := Result.Sorted();
end;

function TBashScriptClient.FetchRawCatalog(): TScriptDataArray;
var
  http: Int32;
  url, response: String;
  json: TJSONObject;
  scriptsArr: TJSONArray;
begin
  Result := [];
  url := 'https://raw.githubusercontent.com/' + Self.Repo + '/' + Self.Branch + '/catalog.json';
  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    response := GetHTTPPage(http, url);
    if GetHTTPResponseCode(http) <> 200 then
      Exit;
  finally
    FreeHTTPClient(http);
  end;

  try
    json.Init(response);
  except
    Exit;
  end;

  try
    scriptsArr := json.optJSONArray('scripts');
    if scriptsArr = nil then
      Exit;
    Result := Self.ScriptsFromCatalogArray(scriptsArr);
  finally
    json.Free();
  end;
end;

function TBashScriptClient.FetchScriptsFromApiTree(): TScriptDataArray;
var
  response, treeSha, path, header, msg: String;
  json, treeObj: TJSONObject;
  tree: TJSONArray;
  i, attempt: Int32;
  script: TScriptData;
begin
  Result := [];
  treeSha := Self.Branch;

  for attempt := 1 to 2 do
  begin
    response := Self.GET('repos/' + Self.Repo + '/git/trees/' + treeSha + '?recursive=1', False);
    if Self.GetHTTPCode() <> 200 then
    begin
      if response.Contains('rate limit') or (Self.GetHTTPCode() = 403) then
        Exit;
      Exit;
    end;

    json.Init(response);
    try
      tree := json.optJSONArray('tree');
      if tree <> nil then
      begin
        for i := 0 to tree.High() do
        begin
          with tree.getJSONObject(i) do
          begin
            if getString('type') <> 'blob' then Continue;
            path := getString('path');
            if not path.EndsWith('.simba') then Continue;
            if path.Contains('BigAussieLauncher') then Continue;
          end;

          header := Self.FetchRawHeader(path);
          if header <> '' then
            script := Self.ParseScriptHeader(header, path)
          else
          begin

            script.URL := path;
            script.LocalPath := '';
            script.Name := ScriptDisplayNameFromPath(path);
            script.ID := path;
            script.Typ := EScriptType.FREE;
            script.Status := EScriptStatus.OFFICIAL;
            script.Source := EScriptSource.BASH;
            script.Revision := 1;
            script.Description := '';
            script.Content := '';
            script.Activities := InferScriptActivities(script.Name, path, []);
          end;
          Result += script;
        end;

        Result := Result.Sorted();
        Exit;
      end;

      treeObj := json.optJSONObject('tree');
      if (treeObj = nil) or (treeObj.optString('sha', '') = '') then
        Exit;

      treeSha := treeObj.getString('sha');
    finally
      json.Free();
    end;
  end;
end;

function TBashScriptClient.MergePremiumScripts(freeScripts: TScriptDataArray): TScriptDataArray;
var
  catalog, entitled: TScriptDataArray;
  i, idx, e: Int32;
  script: TScriptData;
  owned, isTesting, isFull: Boolean;
begin
  Result := freeScripts;

  catalog := BashLicenseClient.FetchPublicCatalog();
  entitled := BashLicenseClient.FetchEntitlements();

  for i := 0 to High(catalog) do
  begin
    script := catalog[i];

    if script.Typ = EScriptType.FREE then
    begin
      idx := Result.Find(script.ID);
      if idx > -1 then
        Result[idx] := script
      else
        Result += script;
      Continue;
    end;

    isTesting := (script.Typ = EScriptType.TESTING) or (script.Typ = EScriptType.TESTING_NO_SUB);
    isFull := (script.Typ = EScriptType.FULL) or (script.Typ = EScriptType.FULL_NO_SUB);
    owned := False;
    for e := 0 to High(entitled) do
      if entitled[e].ID = script.ID then
      begin
        owned := True;
        if (script.Description = '') and (entitled[e].Description <> '') then
          script.Description := entitled[e].Description;
        if entitled[e].Revision > 0 then
          script.Revision := entitled[e].Revision;
        if (Length(script.Activities) = 0) and (Length(entitled[e].Activities) > 0) then
          script.Activities := entitled[e].Activities;
        Break;
      end;

    if owned then
    begin
      if isTesting then
        script.Typ := EScriptType.TESTING
      else if isFull then
        script.Typ := EScriptType.FULL
      else
        script.Typ := EScriptType.PREMIUM;
    end
    else
    begin
      if isTesting then
      begin
        script.Typ := EScriptType.TESTING_NO_SUB;
        if script.Description <> '' then
          script.Description := script.Description + LineEnding + LineEnding +
            'Testing script - enter a license key to Install / Update.'
        else
          script.Description :=
            'Testing script - enter a license key to Install / Update.';
      end
      else if isFull then
      begin
        script.Typ := EScriptType.FULL_NO_SUB;
        if script.Description <> '' then
          script.Description := script.Description + LineEnding + LineEnding +
            'Full - not accepting new sales currently.'
        else
          script.Description :=
            'Full - not accepting new sales currently.';
      end
      else
      begin
        script.Typ := EScriptType.PREMIUM_NO_SUB;
        if script.Description <> '' then
          script.Description := script.Description + LineEnding + LineEnding +
            'Premium script - enter a license key to Install / Update.'
        else
          script.Description :=
            'Premium script - enter a license key to Install / Update.';
      end;
    end;

    idx := Result.Find(script.ID);
    if idx > -1 then
      Result[idx] := script
    else
      Result += script;
  end;

  for e := 0 to High(entitled) do
  begin
    idx := Result.Find(entitled[e].ID);
    if idx > -1 then
    begin
      Result[idx].Typ := entitled[e].Typ;
      Continue;
    end;
    script := entitled[e];
    Result += script;
  end;

  Result := Result.Sorted();
end;

procedure TBashScriptClient.InvalidateCatalog();
begin
  Self.Loaded := False;
  Self.Scripts := [];
  BashLicenseClient.Loaded := False;
  BashLicenseClient.CatalogLoaded := False;
end;

function TBashScriptClient.FetchFreeScriptsFromApi(): TScriptDataArray;
var
  catalog: TScriptDataArray;
  i: Int32;
begin
  Result := [];
  catalog := BashLicenseClient.FetchPublicCatalog(True);
  for i := 0 to High(catalog) do
    if catalog[i].Typ = EScriptType.FREE then
      Result += catalog[i];
  Result := Result.Sorted();
end;

function TBashScriptClient.GetScripts(): TScriptDataArray;
begin
  if Self.ActiveSource = EScriptSource.LOCAL then
    Exit(Self.GetLocalScripts());

  if Self.Loaded then
    Exit(Self.Scripts);

  Result := Self.FetchFreeScriptsFromApi();
  if Result <> [] then
  begin
    Result := Self.MergePremiumScripts(Result);
    Self.Scripts := Result;
    Self.Loaded := True;
    Exit;
  end;

  Result := Self.FetchRawCatalog();
  if Result <> [] then
  begin
    Result := Self.MergePremiumScripts(Result);
    Self.Scripts := Result;
    Self.Loaded := True;
    Exit;
  end;

  Result := Self.FetchScriptsFromApiTree();
  if Result <> [] then
  begin
    Result := Self.MergePremiumScripts(Result);
    Self.Scripts := Result;
    Self.Loaded := True;
    Exit;
  end;

  Result := Self.MergePremiumScripts([]);
  if Result <> [] then
  begin
    Self.Scripts := Result;
    Self.Loaded := True;
    Exit;
  end;

  TerminateScript('BashScriptClient could not load scripts (no catalog.json and API unavailable). Add catalog.json to the scripts repo or retry later.');
end;

function TBashScriptClient.ScanLocalScripts(const directory: String): TScriptDataArray;
var
  files: TStringArray;
  i: Int32;
  path, header, rel: String;
  script: TScriptData;
begin
  Result := [];
  if (directory = '') or (not DirectoryExists(directory)) then
    Exit;

  files := FindFiles(directory, True);
  for i := 0 to High(files) do
  begin
    path := files[i];
    if not path.EndsWith('.simba') then
      Continue;
    if path.Contains('BigAussieLauncher') or path.Contains('B.A.S.HLauncher') then
      Continue;

    if not FileExists(path) then
    begin
      if FileExists(directory + path) then
        path := directory + path
      else
        Continue;
    end;

    try
      header := ReadFileContents(path);
    except
      Continue;
    end;
    if Length(header) > 8192 then
      SetLength(header, 8192);

    rel := path;
    if rel.StartsWith(directory) then
      rel := Copy(rel, Length(directory) + 1, Length(rel) - Length(directory));

    script := Self.ParseScriptHeader(header, rel);
    script.Source := EScriptSource.LOCAL;
    script.Status := EScriptStatus.COMMUNITY;
    script.LocalPath := path;
    script.URL := path;
    script.Description := '';
    if script.Revision = 0 then
      script.Revision := 1;

    Result += script;
  end;

  Result := Result.Sorted();
end;

function TBashScriptClient.GetLocalScripts(): TScriptDataArray;
begin
  if Self.LocalLoaded then
    Exit(Self.LocalScripts);

  Result := Self.ScanLocalScripts(WASPSCRIPTS_DIR);
  Self.LocalScripts := Result;
  Self.LocalLoaded := True;
end;

procedure TBashScriptClient.SetActiveSource(source: EScriptSource);
begin
  Self.ActiveSource := source;
end;

function TBashScriptClient.IsLocalSource(): Boolean;
begin
  Result := Self.ActiveSource = EScriptSource.LOCAL;
end;

procedure TBashScriptClient.DownloadScript(script: TScriptData);
var
  http, code: Int32;
  url, dest: String;
begin
  if (script.Typ = EScriptType.PREMIUM) or (script.Typ = EScriptType.TESTING) or (script.Typ = EScriptType.FULL) then
  begin
    BashLicenseClient.DownloadPremium(script);
    Exit;
  end;

  if (script.Typ = EScriptType.PREMIUM_NO_SUB) or (script.Typ = EScriptType.TESTING_NO_SUB) or (script.Typ = EScriptType.FULL_NO_SUB) then
  begin
    MessageDlg(
      'B.A.S.H',
      '"' + script.Name + '" requires an active license key.' + LineEnding +
      'Enter your key in the License field, then try Install again.',
      TMsgDlgType.mtWarning,
      []
    );
    Exit;
  end;

  if script.Typ = EScriptType.FREE then
  begin
    if BashLicenseClient.DownloadFree(script) then
      Exit;
  end;

  if not ForceDirectories(Self.ScriptsPath) then
  begin
    WriteLn('[B.A.S.H] Failed to create scripts folder: ', Self.ScriptsPath);
    MessageDlg('B.A.S.H', 'Failed to create scripts folder: ' + Self.ScriptsPath, TMsgDlgType.mtError, []);
    Exit;
  end;

  dest := Self.ScriptsPath + ExtractFileName(script.URL).Replace('%20', ' ');
  url := 'https://raw.githubusercontent.com/' + Self.Repo + '/' + Self.Branch + '/' + EncodeGitHubPath(script.URL);

  WriteLn('[B.A.S.H] Downloading script: ', script.Name);
  WriteLn('[B.A.S.H] URL: ', url);
  WriteLn('[B.A.S.H] Dest: ', dest);

  http := InitializeHTTPClient(True);
  try
    SetHTTPHeader(http, 'User-Agent', 'B.A.S.H-Launcher');
    try
      SetSocketTimeout(http, 30000);
    except
    end;


    code := GetHTTPPageEx(http, url, dest);
    WriteLn('[B.A.S.H] Download HTTP code: ', code);

    if (code = 403) or (code = 429) then
    begin
      if FileExists(dest) then DeleteFile(dest);
      MessageDlg('B.A.S.H', 'GitHub rate limited while downloading "' + script.Name + '". Wait about an hour, then retry.', TMsgDlgType.mtWarning, []);
      Exit;
    end;

    if code <> 200 then
    begin
      if FileExists(dest) then DeleteFile(dest);
      MessageDlg('B.A.S.H', 'Failed to download "' + script.Name + '" (HTTP ' + ToStr(code) + ').' + LineEnding + url, TMsgDlgType.mtError, []);
      Exit;
    end;

    if not FileExists(dest) then
    begin
      MessageDlg('B.A.S.H', 'Download reported OK but file was not written: ' + dest, TMsgDlgType.mtError, []);
      Exit;
    end;

    WriteLn('[B.A.S.H] Script saved: ', dest);
  except
    if FileExists(dest) then DeleteFile(dest);
    WriteLn('[B.A.S.H] Download error: ', GetExceptionMessage());
    MessageDlg('B.A.S.H', 'Download error for "' + script.Name + '": ' + GetExceptionMessage(), TMsgDlgType.mtError, []);
  finally
    FreeHTTPClient(http);
  end;
end;

procedure TBashScriptClient.Setup();
begin
  Self.Name := 'Bash Script Client';
  Self.Server := 'https://api.github.com/';
  Self.Repo := BASH_SCRIPTS_REPO;
  Self.Branch := BASH_SCRIPTS_BRANCH;
  Self.ScriptsPath := ScriptPath + 'bigaussie' + DirectorySeparator;
  Self.DownloadPath := LAUNCHER_DATA + 'downloads' + DirectorySeparator;
  Self.ActiveSource := EScriptSource.BASH;
  Self.LocalLoaded := False;

  if not ForceDirectories(Self.ScriptsPath) then
    TerminateScript('BashScriptClient can''t create scripts directory.');
  if not ForceDirectories(Self.DownloadPath) then
    TerminateScript('BashScriptClient can''t create downloads directory.');

  Self.RefreshClient(False);
  AddOnTerminate(@Self.Free);
end;

var
  BashScriptClient: TBashScriptClient;

