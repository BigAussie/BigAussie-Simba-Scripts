  licensePanel.setBevelWidth(0);
  licensePanel.setColor($1A1814);
  licensePanel.SetLeft(TControl.AdjustToDPI(16));
  licensePanel.setWidth(TControl.AdjustToDPI(280));
  licensePanel.setHeight(TControl.AdjustToDPI(72));
  licensePanel.SetTop(panel.getHeight() - TControl.AdjustToDPI(16) - licensePanel.getHeight());

  licenseEdit.Create(licensePanel);
  licenseEdit.SetCaption('License key');
  licenseEdit.Caption.SetFontColor($A89F90);
  licenseEdit.SetTop(0);
  licenseEdit.SetLeft(0);
  licenseEdit.SetHeight(TControl.AdjustToDPI(42));
  licenseEdit.SetWidth(TControl.AdjustToDPI(280));
  licenseEdit.SetName('license_key');
  licenseEdit.SetControlColor($24201C);
  licenseEdit.setControlFontColor($F2EDE4);
  licenseEdit.SetPasswordChar('*');
