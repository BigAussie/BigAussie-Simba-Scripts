  saveBtn.setWidth(TControl.AdjustToDPI(64));
  saveBtn.setHeight(TControl.AdjustToDPI(24));
  saveBtn.SetTop(licenseEdit.GetBottom() + TControl.AdjustToDPI(2));
  saveBtn.SetLeft(0);

  clearBtn.Create(licensePanel);
  clearBtn.setName('license_clear_button');
  clearBtn.SetCaption('Clear');
  clearBtn.SetOnClick(@Self._ClearLicenseKey);
  clearBtn.setWidth(TControl.AdjustToDPI(64));
  clearBtn.setHeight(TControl.AdjustToDPI(24));
  clearBtn.SetTop(saveBtn.GetTop());
  clearBtn.SetLeft(saveBtn.GetLeft() + saveBtn.getWidth() + TControl.AdjustToDPI(6));

  licenseStatus.Create(licensePanel);
  licenseStatus.setName('license_status_label');
